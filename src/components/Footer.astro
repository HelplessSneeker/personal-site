---
import { t, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const imprintPath = locale === 'de' ? '/impressum' : '/en/imprint';
const privacyPath = locale === 'de' ? '/datenschutz' : '/en/privacy';
const home = getLocalizedPath(locale, '/');
const sourceUrl = 'https://github.com/HelplessSneeker/personal-site';
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col footer-mark">
      <span class="colophon-label label-meta">Colophon</span>
      <p class="footer-colophon">
        {t(locale, 'footer.builtWith')} ·
        <a href={sourceUrl} rel="noopener external" target="_blank">
          {t(locale, 'footer.viewSource')} <span aria-hidden="true">↗</span>
        </a>
      </p>
    </div>

    <div class="footer-col footer-meta">
      <span class="colophon-label label-meta">© {year}</span>
      <p class="footer-name">Benjamin Nößler · {locale === 'de' ? 'Wien' : 'Vienna'}</p>
      <p class="footer-direct">
        <a href="mailto:benjamin@noessler.at">
          {locale === 'de' ? 'Direkt schreiben' : 'Email me directly'}
          <span aria-hidden="true"> →</span>
        </a>
      </p>
    </div>

    <nav aria-label={locale === 'de' ? 'Rechtliches' : 'Legal'} class="footer-legal">
      <span class="colophon-label label-meta">{locale === 'de' ? 'Rechtliches' : 'Legal'}</span>
      <ul>
        <li><a href={imprintPath}>{t(locale, 'footer.imprint')}</a></li>
        <li><a href={privacyPath}>{t(locale, 'footer.privacy')}</a></li>
        {Astro.url.pathname !== home && (
          <li><a href={home}>{t(locale, 'footer.backToHome')}</a></li>
        )}
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    padding-block: var(--space-7) var(--space-7);
    color: var(--color-text-muted);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 48rem) {
    .footer-inner {
      grid-template-columns: 1.2fr 1fr auto;
      gap: var(--space-7);
      align-items: start;
    }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .colophon-label {
    color: var(--color-text-subtle);
  }

  .footer-colophon,
  .footer-name,
  .footer-direct {
    font-size: var(--fs-sm);
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer-colophon a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, currentColor 25%, transparent);
    text-underline-offset: 0.2em;
  }
  .footer-colophon a:hover {
    color: var(--color-accent);
    text-decoration-color: currentColor;
  }

  .footer-direct a {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--color-accent) 25%, transparent);
    text-underline-offset: 0.2em;
  }
  .footer-direct a:hover {
    text-decoration-color: currentColor;
  }

  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-legal ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    column-gap: 0;
    font-size: var(--fs-sm);
  }
  .footer-legal li {
    display: inline-flex;
    align-items: baseline;
  }
  .footer-legal li:not(:last-child)::after {
    content: '·';
    color: var(--color-text-subtle);
    margin-inline: 0.55em;
  }
  .footer-legal a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .footer-legal a:hover {
    color: var(--color-accent);
  }
</style>
