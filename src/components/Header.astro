---
import LanguageToggle from './LanguageToggle.astro';
import { t, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getLocalizedPath(locale, '/');
const navLinks = [
  { href: `${home}#services`, label: t(locale, 'nav.services') },
  { href: `${home}#work`, label: t(locale, 'nav.work') },
  { href: `${home}#about`, label: t(locale, 'nav.about') },
  { href: `${home}#contact`, label: t(locale, 'nav.contact') },
];
---
<header class="site-header">
  <div class="container header-inner">
    <div class="site-mark">
      <a href={home} class="mark-name" rel="home">Benjamin Nößler</a>
      <span class="mark-sep" aria-hidden="true">/</span>
      <a
        href={`${home}#contact`}
        class="mark-tag"
        aria-label={locale === 'de' ? 'Anfrage stellen' : 'Send an inquiry'}
      >{t(locale, 'header.availabilityTag')}</a>
    </div>

    <nav aria-label="Primary" class="site-nav">
      <ul>
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <LanguageToggle currentLocale={locale} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-rule);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-3);
  }

  .site-mark {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    white-space: nowrap;
    min-width: 0;
  }

  .mark-name {
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    font-size: var(--fs-sm);
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-decoration: none;
  }
  .mark-name:hover {
    color: var(--color-text);
    text-decoration: none;
  }
  .mark-sep {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
  }
  .mark-tag {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .mark-tag:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 40rem) {
    .mark-sep,
    .mark-tag {
      display: none;
    }
  }

  .site-nav ul {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav a {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    padding-block: var(--space-1);
    border-bottom: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }
  .site-nav a:hover,
  .site-nav a[aria-current="location"] {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 34rem) {
    .header-inner {
      flex-wrap: wrap;
      row-gap: var(--space-2);
    }
    .site-nav {
      order: 3;
      flex-basis: 100%;
      padding-block-start: var(--space-2);
      border-top: 1px solid var(--color-rule);
    }
    .site-nav ul {
      gap: var(--space-4);
    }
    .site-nav a {
      font-family: var(--font-mono);
      font-feature-settings: var(--font-features-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--tracking-smallcaps);
      text-transform: uppercase;
    }
  }
</style>
