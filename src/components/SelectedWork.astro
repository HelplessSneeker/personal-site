---
import { t, type Locale } from '../i18n/util';
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<section class="section" id="work" aria-labelledby="work-heading">
  <div class="container">
    <h2 id="work-heading" class="section-label">{t(locale, 'work.label')}</h2>
    <p class="work-intro">{t(locale, 'work.intro')}</p>
    <div class="project-list">
      {projects.map((project) => <ProjectCard project={project} locale={locale} />)}
    </div>
  </div>
</section>

<style>
  .work-intro {
    font-size: var(--fs-md);
    color: var(--color-text-muted);
    max-width: var(--container-prose);
    margin-bottom: var(--space-6);
  }
  .project-list {
    display: flex;
    flex-direction: column;
  }
</style>
