---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Proof from '../components/Proof.astro';
import Services from '../components/Services.astro';
import Trust from '../components/Trust.astro';
import SelectedWork from '../components/SelectedWork.astro';
import FromEmployment from '../components/FromEmployment.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import { t, getAltUrl } from '../i18n/util';

export const prerender = true;

const locale = 'de' as const;
const altUrl = getAltUrl(Astro.url.pathname, locale);

const sections = [
  { id: 'top', label: t(locale, 'nav.top') },
  { id: 'services', label: t(locale, 'nav.services') },
  { id: 'trust', label: t(locale, 'trust.label') },
  { id: 'work', label: t(locale, 'nav.work') },
  { id: 'from-employment', label: t(locale, 'fromEmployment.label') },
  { id: 'about', label: t(locale, 'nav.about') },
  { id: 'contact', label: t(locale, 'nav.contact') },
];
---
<BaseLayout
  title={t(locale, 'site.title')}
  description={t(locale, 'site.description')}
  locale={locale}
  altLocaleUrl={altUrl}
  canonicalPath="/"
  sections={sections}
>
  <Header locale={locale} />
  <main id="main">
    <Hero locale={locale} />
    <Proof locale={locale} />
    <Services locale={locale} />
    <Trust locale={locale} />
    <SelectedWork locale={locale} />
    <FromEmployment locale={locale} />
    <About locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
