---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const metaItems = tArray(locale, 'pricing.hero.metaItems');
---
<section class="section pricing-hero" id="top" aria-labelledby="pricing-hero-heading">
  <div class="container pricing-hero-grid">
    <div class="pricing-hero-text">
      <span class="pricing-hero-rule" aria-hidden="true"></span>
      <p class="pricing-hero-kicker label-meta">{t(locale, 'pricing.hero.kicker')}</p>
      <h1 id="pricing-hero-heading" class="pricing-hero-headline">{t(locale, 'pricing.hero.headline')}</h1>
      <p class="pricing-hero-body">{t(locale, 'pricing.hero.body')}</p>
    </div>

    {metaItems.length > 0 && (
      <aside class="pricing-hero-meta" aria-label={t(locale, 'pricing.hero.kicker')}>
        <ul class="pricing-hero-meta-list">
          {metaItems.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    )}
  </div>
</section>

<style>
  /* Deep-page hero. Lighter than the homepage Hero — page-title size,
     not display size. No CTA pair here; the booking CTA closes the page. */
  .pricing-hero {
    padding-block: var(--space-8) var(--space-7);
  }
  .pricing-hero.section,
  .pricing-hero + .section {
    border-top: none;
  }
  @media (min-width: 48rem) {
    .pricing-hero {
      padding-block: clamp(var(--space-9), 10vh, 8rem) var(--space-8);
    }
  }

  .pricing-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  @media (min-width: 48rem) {
    .pricing-hero-grid {
      grid-template-columns: minmax(0, 1.4fr) minmax(11rem, 1fr);
      gap: var(--space-7);
    }
  }

  .pricing-hero-rule {
    display: block;
    width: var(--space-7);
    height: 1px;
    background: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .pricing-hero-kicker {
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-4) 0;
  }

  .pricing-hero-headline {
    font-size: var(--fs-xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-heading-xl);
    margin: 0 0 var(--space-5) 0;
    max-width: 30ch;
    text-wrap: balance;
  }
  @media (min-width: 48rem) {
    .pricing-hero-headline {
      font-size: var(--fs-2xl);
      letter-spacing: var(--tracking-display);
    }
  }

  .pricing-hero-body {
    font-size: var(--fs-lg);
    line-height: 1.45;
    color: var(--color-text);
    max-width: 56ch;
    text-wrap: pretty;
  }

  .pricing-hero-meta {
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-4);
  }
  @media (min-width: 48rem) {
    .pricing-hero-meta {
      border-top: none;
      border-left: 1px solid var(--color-rule);
      padding-top: 0;
      padding-left: var(--space-5);
    }
  }

  .pricing-hero-meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
