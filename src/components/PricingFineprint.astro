---
import { t, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<section class="section pricing-fineprint" aria-labelledby="pricing-fineprint-heading">
  <div class="container">
    <h2 id="pricing-fineprint-heading" class="visually-hidden">{t(locale, 'pricing.hourly.label')}</h2>

    <div class="pricing-fineprint-grid">
      <article class="pricing-fineprint-item">
        <p class="pricing-fineprint-label label-meta">{t(locale, 'pricing.hourly.label')}</p>
        <p class="pricing-fineprint-title">{t(locale, 'pricing.hourly.title')}</p>
        <p class="pricing-fineprint-body">{t(locale, 'pricing.hourly.body')}</p>
      </article>

      <article class="pricing-fineprint-item">
        <p class="pricing-fineprint-label label-meta">{t(locale, 'pricing.domain.label')}</p>
        <p class="pricing-fineprint-title">{t(locale, 'pricing.domain.title')}</p>
        <p class="pricing-fineprint-body">{t(locale, 'pricing.domain.body')}</p>
      </article>
    </div>

    <p class="pricing-fineprint-tax">{t(locale, 'pricing.taxNote')}</p>
  </div>
</section>

<style>
  .pricing-fineprint {
    padding-block: var(--space-7);
  }
  @media (min-width: 48rem) {
    .pricing-fineprint {
      padding-block: var(--space-8);
    }
  }

  .pricing-fineprint-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 48rem) {
    .pricing-fineprint-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-7);
    }
  }

  .pricing-fineprint-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pricing-fineprint-label {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .pricing-fineprint-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-heading-lg);
    margin: 0;
    color: var(--color-text);
    text-wrap: balance;
  }

  .pricing-fineprint-body {
    font-size: var(--fs-md);
    line-height: var(--lh-normal);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 52ch;
    text-wrap: pretty;
  }

  .pricing-fineprint-tax {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    color: var(--color-text-muted);
    max-width: 64ch;
    text-wrap: pretty;
  }
</style>
