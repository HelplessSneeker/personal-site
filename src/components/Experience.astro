---
import { t, type Locale } from '../i18n/util';
import { experience } from '../data/experience';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const presentLabel = t(locale, 'experience.presentLabel');
---
<section class="section" id="experience" aria-labelledby="experience-heading">
  <div class="container">
    <h2 id="experience-heading" class="section-label">{t(locale, 'experience.label')}</h2>
    <ol class="experience-list">
      {experience.map((job) => {
        const role = locale === 'de' ? job.roleDe : job.roleEn;
        const toLabel = job.to === 'present' ? presentLabel : job.to;
        return (
          <li class="experience-row">
            <span class="company">{job.company}</span>
            <span class="role">{role}</span>
            <span class="years tabular">{job.from}—{toLabel}</span>
          </li>
        );
      })}
    </ol>
    <p class="cv-link">
      <a href="/cv.pdf" rel="noopener" type="application/pdf">
        {t(locale, 'experience.cvLinkLabel')} ↗
      </a>
    </p>
  </div>
</section>

<style>
  .experience-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .experience-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: var(--space-3) var(--space-5);
    align-items: baseline;
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-md);
  }
  .experience-row:last-child {
    border-bottom: none;
  }
  .company {
    font-weight: 500;
    color: var(--color-text);
  }
  .role {
    color: var(--color-text-muted);
  }
  .years {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    white-space: nowrap;
  }
  .cv-link {
    margin-top: var(--space-5);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 40rem) {
    .experience-row {
      grid-template-columns: 1fr auto;
    }
    .role {
      grid-column: 1 / -1;
      font-size: var(--fs-sm);
    }
  }
</style>
