---
import { t, type Locale } from '../i18n/util';
import { projects } from '../data/projects';
import EmploymentCard from './EmploymentCard.astro';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const employmentProjects = projects.filter((p) => p.status === 'case-study');
---
<section class="section from-employment-section" id="from-employment" aria-labelledby="from-employment-heading">
  <div class="container">
    <h2 id="from-employment-heading" class="section-label">{t(locale, 'fromEmployment.label')}</h2>
    <p class="from-employment-intro">{t(locale, 'fromEmployment.intro')}</p>

    <div class="employment-list" role="list">
      {employmentProjects.map((project) => (
        <EmploymentCard project={project} locale={locale} />
      ))}
    </div>
  </div>
</section>

<style>
  /* Sit closer to the Selected Work section above so the reader registers
     this as a smaller "for context" subsection rather than a fresh peer. */
  .from-employment-section {
    padding-block-start: var(--section-continued);
  }

  /* Continuation-style intro: muted body voice, not the strong .section-lede.
     Signals "context for what came before," not a fresh argument. */
  .from-employment-intro {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-7);
    text-wrap: pretty;
  }

  /* Editorial stack of employment entries — one per row, separated by a
     thin rule. Echoes the SelectedWork pattern; replaces the previous
     2-col card grid which read as "card catalog" rather than editorial. */
  .employment-list {
    display: flex;
    flex-direction: column;
  }

  .employment-list > * + * {
    margin-top: var(--space-7);
    padding-top: var(--space-7);
    border-top: 1px solid var(--color-rule);
  }
  @media (min-width: 48rem) {
    .employment-list > * + * {
      margin-top: var(--space-8);
      padding-top: var(--space-8);
    }
  }
</style>
