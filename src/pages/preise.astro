---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PricingHero from '../components/PricingHero.astro';
import PricingBase from '../components/PricingBase.astro';
import PricingAddons from '../components/PricingAddons.astro';
import PricingBundle from '../components/PricingBundle.astro';
import PricingFull from '../components/PricingFull.astro';
import PricingFineprint from '../components/PricingFineprint.astro';
import PricingBooking from '../components/PricingBooking.astro';
import { t, getAltUrl } from '../i18n/util';

export const prerender = true;

const locale = 'de' as const;
const altUrl = getAltUrl(Astro.url.pathname, locale);

const sections = [
  { id: 'top', label: t(locale, 'nav.top') },
  { id: 'base', label: t(locale, 'pricing.base.title') },
  { id: 'addons', label: t(locale, 'pricing.addonsSection.label') },
  { id: 'booking', label: t(locale, 'nav.contact') },
];
---
<BaseLayout
  title={t(locale, 'pricing.metaTitle')}
  description={t(locale, 'pricing.metaDescription')}
  locale={locale}
  altLocaleUrl={altUrl}
  canonicalPath="/preise"
  sections={sections}
>
  <Header locale={locale} />
  <main id="main">
    <PricingHero locale={locale} />
    <PricingBase locale={locale} />
    <PricingAddons locale={locale} />
    <PricingBundle locale={locale} />
    <PricingFull locale={locale} />
    <PricingFineprint locale={locale} />
    <PricingBooking locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
