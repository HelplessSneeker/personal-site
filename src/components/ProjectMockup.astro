---
export interface Props {
  variant?: 'mockup-calendar' | 'mockup-scanner' | 'mockup-healthcare' | 'mockup-industrial';
  title: string;
}

const { variant = 'mockup-calendar', title } = Astro.props;
---
<div class={`mockup mockup--${variant}`} aria-hidden="true">
  <div class="mockup-chrome">
    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
  </div>
  <div class="mockup-content">
    {variant === 'mockup-calendar' && (
      <div class="calendar">
        <div class="cal-header">
          {[...Array(7)].map(() => <span class="cal-day-label"></span>)}
        </div>
        <div class="cal-grid">
          {[...Array(35)].map((_, i) => <span class={`cal-cell ${[4, 11, 17, 23].includes(i) ? 'has-event' : ''}`}></span>)}
        </div>
      </div>
    )}
    {variant === 'mockup-scanner' && (
      <div class="scanner">
        <div class="doc"><div class="line"></div><div class="line short"></div><div class="line"></div><div class="line"></div><div class="line short"></div></div>
        <div class="beam"></div>
      </div>
    )}
    {variant === 'mockup-healthcare' && (
      <div class="chat">
        <div class="bubble left"><div class="line"></div><div class="line short"></div></div>
        <div class="bubble right"><div class="line"></div></div>
        <div class="bubble left"><div class="line"></div><div class="line"></div></div>
        <div class="lock" aria-hidden="true">🔒</div>
      </div>
    )}
    {variant === 'mockup-industrial' && (
      <div class="industrial">
        <div class="gauge"><div class="gauge-needle"></div></div>
        <div class="bars">
          <span style="height: 40%"></span>
          <span style="height: 65%"></span>
          <span style="height: 50%"></span>
          <span style="height: 80%"></span>
          <span style="height: 35%"></span>
        </div>
      </div>
    )}
  </div>
  <span class="mockup-title">{title}</span>
</div>

<style>
  .mockup {
    position: relative;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .mockup-chrome {
    display: flex;
    gap: 6px;
    padding: 10px 12px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .mockup-chrome .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-border);
  }
  .mockup-content {
    flex: 1;
    padding: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mockup-title {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
  }

  /* Calendar */
  .calendar {
    width: 100%;
    display: grid;
    gap: 4px;
  }
  .cal-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-day-label {
    height: 6px;
    background: var(--color-border);
    border-radius: 2px;
  }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-cell {
    aspect-ratio: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
  }
  .cal-cell.has-event {
    background: var(--color-accent-subtle);
    border-color: var(--color-accent);
  }

  /* Scanner */
  .scanner {
    position: relative;
    width: 60%;
    height: 80%;
  }
  .doc {
    height: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .doc .line {
    height: 5px;
    background: var(--color-border);
    border-radius: 2px;
  }
  .doc .line.short { width: 60%; }
  .beam {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
  }

  /* Healthcare chat */
  .chat {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bubble {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 6px 10px;
    max-width: 65%;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bubble.left { align-self: flex-start; }
  .bubble.right { align-self: flex-end; background: var(--color-accent-subtle); border-color: var(--color-accent); }
  .bubble .line {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    width: 100%;
  }
  .bubble .line.short { width: 50%; }
  .lock {
    position: absolute;
    top: -4px;
    right: -4px;
    font-size: 14px;
    background: var(--color-bg);
    padding: 2px 4px;
    border-radius: 4px;
    border: 1px solid var(--color-accent);
  }

  /* Industrial */
  .industrial {
    display: flex;
    gap: var(--space-5);
    align-items: flex-end;
    width: 100%;
    height: 100%;
  }
  .gauge {
    width: 80px;
    height: 80px;
    border: 2px solid var(--color-border);
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
    align-self: center;
  }
  .gauge-needle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    transform-origin: 0 50%;
    transform: rotate(-45deg);
  }
  .gauge::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  .bars {
    display: flex;
    gap: 6px;
    align-items: flex-end;
    height: 100%;
    flex: 1;
  }
  .bars span {
    flex: 1;
    background: var(--color-border);
    border-radius: 2px 2px 0 0;
  }
  .bars span:nth-child(4) {
    background: var(--color-accent);
  }

  @media (prefers-color-scheme: dark) {
    .mockup-chrome { background: var(--color-surface); }
    .mockup { background: var(--color-bg); }
  }
</style>
