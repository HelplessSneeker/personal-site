---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = tArray(locale, 'currently.items');
---
<section class="section" id="currently" aria-labelledby="currently-heading">
  <div class="container">
    <h2 id="currently-heading" class="section-label">{t(locale, 'currently.label')}</h2>
    <ul class="currently-list">
      {items.map((item) => (
        <li>
          <span class="arrow" aria-hidden="true">→</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .currently-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: var(--fs-md);
    max-width: var(--container-prose);
  }
  .currently-list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }
  .arrow {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 500;
  }
</style>
