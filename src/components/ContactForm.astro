---
import { getDict, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const form = dict.contact.form;

// Serialize form strings for the client-side handler
const messages = {
  submitting: form.submittingLabel,
  submit: form.submitLabel,
  successHeading: form.successHeading,
  successBody: form.successBody,
  errorHeading: form.errorHeading,
  errorBody: form.errorBody,
  validation: form.validation,
};
---
<form
  class="contact-form"
  id="contact-form"
  method="POST"
  action="/api/contact"
  novalidate
  data-locale={locale}
>
  <input type="hidden" name="locale" value={locale} />

  <div class="field">
    <label class="label-meta" for="cf-name">
      {form.nameLabel}
      <span class="required" aria-hidden="true">*</span>
    </label>
    <input
      id="cf-name"
      name="name"
      type="text"
      autocomplete="name"
      required
      maxlength="200"
      placeholder={form.namePlaceholder}
      aria-describedby="cf-name-error"
    />
    <p class="field-error" id="cf-name-error" aria-live="polite"></p>
  </div>

  <div class="field">
    <label class="label-meta" for="cf-email">
      {form.emailLabel}
      <span class="required" aria-hidden="true">*</span>
    </label>
    <input
      id="cf-email"
      name="email"
      type="email"
      autocomplete="email"
      required
      maxlength="320"
      placeholder={form.emailPlaceholder}
      aria-describedby="cf-email-error"
    />
    <p class="field-error" id="cf-email-error" aria-live="polite"></p>
  </div>

  <div class="field">
    <label class="label-meta" for="cf-projectType">
      {form.projectTypeLabel}
      <span class="required" aria-hidden="true">*</span>
    </label>
    <span class="select-wrap">
      <select
        id="cf-projectType"
        name="projectType"
        required
        aria-describedby="cf-projectType-hint cf-projectType-error"
      >
        <option value="">{form.projectTypeNone}</option>
        <option value="landing">{form.projectTypeOptions.landing}</option>
        <option value="fullstack">{form.projectTypeOptions.fullstack}</option>
        <option value="other">{form.projectTypeOptions.other}</option>
      </select>
    </span>
    <p class="field-hint" id="cf-projectType-hint">{form.projectTypeHint}</p>
    <p class="field-error" id="cf-projectType-error" aria-live="polite"></p>
  </div>

  <div class="field">
    <label class="label-meta" for="cf-message">
      {form.messageLabel}
      <span class="required" aria-hidden="true">*</span>
    </label>
    <textarea
      id="cf-message"
      name="message"
      rows="6"
      required
      minlength="20"
      maxlength="5000"
      placeholder={form.messagePlaceholder}
      aria-describedby="cf-message-error"
    ></textarea>
    <p class="field-error" id="cf-message-error" aria-live="polite"></p>
  </div>

  <div class="hp-field" aria-hidden="true">
    <label>
      Company
      <input type="text" name="company" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <div class="form-actions">
    <button type="submit" class="submit-btn">
      {form.submitLabel}
    </button>
  </div>

  <div class="form-status" role="status" aria-live="polite" hidden></div>
</form>

<script is:inline type="application/json" id="cf-messages" set:html={JSON.stringify(messages)}></script>

<script>
  type ValidationKeys =
    | 'nameRequired'
    | 'emailRequired'
    | 'emailInvalid'
    | 'messageRequired'
    | 'messageTooShort'
    | 'projectTypeRequired';

  interface Messages {
    submitting: string;
    submit: string;
    successHeading: string;
    successBody: string;
    errorHeading: string;
    errorBody: string;
    validation: Record<ValidationKeys, string>;
  }

  const messagesNode = document.getElementById('cf-messages');
  if (!messagesNode) throw new Error('contact form messages not found');
  const messages: Messages = JSON.parse(messagesNode.textContent ?? '{}');

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (!form) throw new Error('contact form not found');

  const submitBtn = form.querySelector<HTMLButtonElement>('.submit-btn');
  const statusNode = form.querySelector<HTMLDivElement>('.form-status');

  function setError(fieldId: string, message: string) {
    const el = document.getElementById(`${fieldId}-error`);
    if (el) el.textContent = message;
    const input = document.getElementById(fieldId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
  }

  function clearErrors() {
    ['cf-name', 'cf-email', 'cf-projectType', 'cf-message'].forEach((id) => setError(id, ''));
    if (statusNode) {
      statusNode.hidden = true;
      statusNode.classList.remove('form-status--success', 'form-status--error');
      statusNode.innerHTML = '';
    }
  }

  function showStatus(kind: 'success' | 'error', heading: string, body: string) {
    if (!statusNode) return;
    statusNode.innerHTML = `<strong>${heading}</strong><p>${body}</p>`;
    statusNode.classList.remove('form-status--success', 'form-status--error');
    statusNode.classList.add(`form-status--${kind}`);
    statusNode.hidden = false;
  }

  function validateEmail(value: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearErrors();

    const formData = new FormData(form);
    const name = String(formData.get('name') ?? '').trim();
    const email = String(formData.get('email') ?? '').trim();
    const message = String(formData.get('message') ?? '').trim();
    const projectType = String(formData.get('projectType') ?? '');
    const locale = String(formData.get('locale') ?? 'de');
    const honeypot = String(formData.get('company') ?? '').trim();

    // Bot trap: if the hidden 'company' field is filled, pretend success
    // and bail without contacting the API. Real users can't see the field.
    if (honeypot) {
      showStatus('success', messages.successHeading, messages.successBody);
      form.reset();
      return;
    }

    let hasError = false;
    if (!name) { setError('cf-name', messages.validation.nameRequired); hasError = true; }
    if (!email) { setError('cf-email', messages.validation.emailRequired); hasError = true; }
    else if (!validateEmail(email)) { setError('cf-email', messages.validation.emailInvalid); hasError = true; }
    if (!projectType) { setError('cf-projectType', messages.validation.projectTypeRequired); hasError = true; }
    if (!message) { setError('cf-message', messages.validation.messageRequired); hasError = true; }
    else if (message.length < 20) { setError('cf-message', messages.validation.messageTooShort); hasError = true; }
    if (hasError) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = messages.submitting;
    }

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ name, email, message, projectType, locale }),
      });

      const result = await response.json().catch(() => ({ ok: false }));

      if (response.ok && result.ok) {
        showStatus('success', messages.successHeading, messages.successBody);
        form.reset();
      } else {
        showStatus('error', messages.errorHeading, messages.errorBody);
      }
    } catch {
      showStatus('error', messages.errorHeading, messages.errorBody);
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = messages.submit;
      }
    }
  });
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .field label {
    color: var(--color-text-subtle);
  }
  .required {
    color: var(--color-accent);
    margin-left: 2px;
  }
  .field input,
  .field textarea,
  .field select {
    width: 100%;
    padding: var(--space-3) 0;
    font: inherit;
    font-size: var(--fs-md);
    color: var(--color-text);
    background: transparent;
    border: 0;
    border-bottom: 1.5px solid var(--color-border-strong);
    border-radius: 0;
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-text-subtle);
  }
  .field input:hover,
  .field textarea:hover,
  .field select:hover {
    border-bottom-color: var(--color-text-muted);
  }
  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    outline: none;
    border-bottom-color: var(--color-accent);
    box-shadow: 0 1.5px 0 0 var(--color-accent);
  }
  .field input[aria-invalid="true"],
  .field textarea[aria-invalid="true"] {
    border-bottom-color: var(--color-danger);
  }
  .field textarea {
    resize: vertical;
    min-height: 8rem;
    padding-top: var(--space-2);
  }
  .select-wrap {
    position: relative;
    display: block;
  }
  .field select {
    appearance: none;
    padding-right: var(--space-6);
  }
  /* Chevron via a masked pseudo so the color tracks --color-text-subtle
     in both themes — no hex duplication, no theme-fork. */
  .select-wrap::after {
    content: '';
    position: absolute;
    right: 8px;
    top: 50%;
    width: 10px;
    height: 6px;
    margin-top: -3px;
    background-color: var(--color-text-subtle);
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>") no-repeat center / 10px 6px;
            mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>") no-repeat center / 10px 6px;
    pointer-events: none;
  }
  .field-error {
    font-size: var(--fs-sm);
    color: var(--color-danger);
    min-height: 1em;
    margin: 0;
  }
  .field-error:empty {
    display: none;
  }

  .field-hint {
    font-size: var(--fs-sm);
    line-height: 1.45;
    color: var(--color-text-subtle);
    margin: 0;
  }

  .hp-field {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-actions {
    margin-top: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    font-weight: var(--weight-medium);
    color: var(--color-bg);
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    cursor: pointer;
    min-height: 44px;
    transition: background-color var(--transition), border-color var(--transition);
  }
  .submit-btn::after {
    content: '→';
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    transition: transform var(--transition);
  }
  .submit-btn:hover:not(:disabled) {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }
  .submit-btn:hover:not(:disabled)::after {
    transform: translateX(2px);
  }
  .submit-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .form-status {
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }
  .form-status strong {
    display: block;
    margin-bottom: var(--space-1);
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: var(--weight-medium);
  }
  .form-status p {
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--lh-snug);
  }
  .form-status--success {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
    color: var(--color-text);
  }
  .form-status--success strong {
    color: var(--color-accent);
  }
  .form-status--error {
    border-color: var(--color-danger);
    background: var(--color-danger-bg);
    color: var(--color-text);
  }
  .form-status--error strong {
    color: var(--color-danger);
  }
</style>
