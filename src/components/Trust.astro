---
import { t, getDict, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const steps = dict.trust.process.steps;
---
<section class="section trust-section" id="trust" aria-labelledby="trust-heading">
  <div class="container">
    <h2 id="trust-heading" class="section-label">{t(locale, 'trust.label')}</h2>

    <ol class="trust-steps" aria-label={t(locale, 'trust.process.label')}>
      {steps.map((step, i) => (
        <li class="trust-step">
          <p class="step-index" aria-hidden="true">
            <span>{String(i + 1).padStart(2, '0')}</span>
            <span class="rule"></span>
          </p>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  /* Tighten the gap above Trust so it reads as a continuation of Services
     (offer → how-we-work) rather than a fresh, unrelated section. */
  .trust-section {
    padding-block-start: var(--section-continued);
  }

  /* Vertical editorial list — same composition vocabulary as the Services
     section's `.service-index` (mono numeral + flex-grow rule line above
     the title). Was a 3-column grid; the grid shape pattern-matched against
     "consultancy how-it-works trio" before readers got to the copy. */
  .trust-steps {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    max-width: 52rem;
  }

  .trust-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .step-index {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
  }
  .step-index .rule {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
    display: block;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-lg);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0;
  }

  .step-body {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text-muted);
    max-width: 50ch;
    text-wrap: pretty;
  }
</style>
