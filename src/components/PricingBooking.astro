---
import { t, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ctaUrl = t(locale, 'pricing.booking.ctaUrl');
const fallbackEmail = t(locale, 'pricing.booking.fallbackEmail');
---
<section class="section pricing-booking" id="booking" aria-labelledby="pricing-booking-heading">
  <div class="container pricing-booking-inner">
    <p class="pricing-booking-kicker label-meta">{t(locale, 'pricing.booking.kicker')}</p>
    <h2 id="pricing-booking-heading" class="pricing-booking-title">{t(locale, 'pricing.booking.title')}</h2>
    <p class="pricing-booking-body">{t(locale, 'pricing.booking.body')}</p>

    <div class="pricing-booking-actions">
      <a
        href={ctaUrl}
        class="btn btn-primary pricing-booking-cta"
        rel="noopener"
        target="_blank"
      >
        {t(locale, 'pricing.booking.ctaLabel')}
        <span class="pricing-booking-cta-arrow" aria-hidden="true">→</span>
      </a>

      <p class="pricing-booking-fallback">
        {t(locale, 'pricing.booking.fallbackLabel')}{' '}
        <a href={`mailto:${fallbackEmail}`}>{fallbackEmail}</a>
      </p>
    </div>
  </div>
</section>

<style>
  /* "pause" rhythm — the closing chord of the page. The single conversion
     moment after the entire pricing surface has been laid out. */
  .pricing-booking {
    padding-block: var(--space-9);
  }
  @media (min-width: 48rem) {
    .pricing-booking {
      padding-block: clamp(var(--space-10), 12vh, 10rem);
    }
  }

  .pricing-booking-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    max-width: var(--container-wide);
  }

  .pricing-booking-kicker {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .pricing-booking-title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: var(--weight-medium);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
    margin: 0;
    max-width: 18ch;
    text-wrap: balance;
  }

  .pricing-booking-body {
    font-size: var(--fs-lg);
    line-height: 1.45;
    color: var(--color-text);
    margin: 0;
    max-width: 50ch;
    text-wrap: pretty;
  }

  .pricing-booking-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    margin-top: var(--space-3);
  }
  @media (min-width: 36rem) {
    .pricing-booking-actions {
      flex-direction: row;
      align-items: center;
      gap: var(--space-6);
    }
  }

  .pricing-booking-cta {
    /* Inherits .btn .btn-primary from global.css */
  }

  .pricing-booking-cta-arrow {
    transition: transform var(--transition);
  }
  .pricing-booking-cta:hover .pricing-booking-cta-arrow {
    transform: translateX(0.15em);
  }
  @media (prefers-reduced-motion: reduce) {
    .pricing-booking-cta-arrow {
      transition: none;
    }
    .pricing-booking-cta:hover .pricing-booking-cta-arrow {
      transform: none;
    }
  }

  .pricing-booking-fallback {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .pricing-booking-fallback a {
    color: var(--color-text);
    text-decoration-color: color-mix(in oklab, var(--color-text) 35%, transparent);
  }
  .pricing-booking-fallback a:hover {
    color: var(--color-accent);
  }
</style>
