---
import LanguageToggle from './LanguageToggle.astro';
import { t, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getLocalizedPath(locale, '/');
const pricingPath = getLocalizedPath(locale, locale === 'de' ? '/preise' : '/pricing');
const navLinks = [
  { href: `${home}#services`, label: t(locale, 'nav.services') },
  { href: pricingPath, label: t(locale, 'nav.pricing') },
  { href: `${home}#work`, label: t(locale, 'nav.work') },
  { href: `${home}#about`, label: t(locale, 'nav.about') },
  { href: `${home}#contact`, label: t(locale, 'nav.contact') },
];
---
<header class="site-header">
  <div class="container header-inner">
    <div class="site-mark">
      <a href={home} class="mark-name" rel="home">
        <svg
          class="mark-logo"
          viewBox="0 0 240 240"
          width="28"
          height="28"
          aria-hidden="true"
          focusable="false"
        >
          {/* "bfn" outlined from General Sans Bold (700). Kept as paths so the
              mark renders identically on every OS — system-font text in SVGs
              shapes differently per platform. */}
          <rect width="240" height="240" rx="52" />
          <path d="M93.6 128.92Q93.6 138.16 90 145.78Q86.4 153.4 79.98 157.9Q73.56 162.4 64.8 162.4Q59.16 162.4 54.36 160.18Q49.56 157.96 45.6 153.88L45.6 161.2L26.76 161.2L26.76 75.04L47.28 75.04L47.28 102.64Q51.12 99.04 55.44 97.24Q59.76 95.44 64.8 95.44Q73.56 95.44 79.98 99.88Q86.4 104.32 90 111.94Q93.6 119.56 93.6 128.92ZM72.24 128.92Q72.24 121.12 68.4 117.52Q64.56 113.92 59.88 113.92Q56.76 113.92 53.94 115.48Q51.12 117.04 49.32 120.34Q47.52 123.64 47.52 128.8Q47.52 133.84 49.26 137.2Q51 140.56 53.88 142.24Q56.76 143.92 59.88 143.92Q64.56 143.92 68.4 140.2Q72.24 136.48 72.24 128.92ZM129.72 161.2L109.2 161.2L109.2 114.52L97.2 114.52L97.2 96.64L109.2 96.64L109.2 94.36Q109.2 84.4 114.6 79Q120 73.6 130.8 73.6Q134.28 73.6 137.22 74.2Q140.16 74.8 142.44 75.76L142.44 91.96Q141.24 91.36 139.44 91.06Q137.64 90.76 135.96 90.76Q133.32 90.76 131.52 91.66Q129.72 92.56 129.72 94.84L129.72 96.64L145.56 96.64L145.56 114.52L129.72 114.52ZM174 127.24L174 161.2L153.48 161.2L153.48 96.64L172.32 96.64L172.32 104.44Q176.16 100.24 180.78 97.84Q185.4 95.44 191.52 95.44Q201.12 95.44 207.18 101.68Q213.24 107.92 213.24 119.68L213.24 161.2L192.72 161.2L192.72 126.52Q192.72 120.4 190.5 117.16Q188.28 113.92 183.6 113.92Q181.08 113.92 178.86 115.24Q176.64 116.56 175.32 119.44Q174 122.32 174 127.24Z" />
        </svg>
        <span class="mark-name-text">Benjamin Nößler</span>
      </a>
      <span class="mark-sep" aria-hidden="true">/</span>
      <a
        href={`${home}#contact`}
        class="mark-tag"
        aria-label={t(locale, 'header.inquiryAria')}
      >{t(locale, 'header.availabilityTag')}</a>
    </div>

    <nav aria-label={t(locale, 'nav.primary')} class="site-nav">
      <ul>
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <LanguageToggle currentLocale={locale} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-rule);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-3);
  }

  .site-mark {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    white-space: nowrap;
    min-width: 0;
  }

  .mark-name {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    font-size: var(--fs-sm);
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-decoration: none;
  }
  .mark-name:hover {
    color: var(--color-text);
    text-decoration: none;
  }
  .mark-logo {
    display: block;
    flex-shrink: 0;
    width: 1.625rem;
    height: 1.625rem;
    transition: transform var(--transition);
  }
  .mark-logo rect {
    fill: var(--color-text);
  }
  .mark-logo path {
    fill: var(--color-bg);
  }
  .mark-name:hover .mark-logo {
    transform: scale(1.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .mark-logo {
      transition: none;
    }
    .mark-name:hover .mark-logo {
      transform: none;
    }
  }
  .mark-sep {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
  }
  .mark-tag {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .mark-tag:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 40rem) {
    .mark-sep,
    .mark-tag {
      display: none;
    }
  }

  .site-nav ul {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav a {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    padding-block: var(--space-1);
    border-bottom: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }
  .site-nav a:hover,
  .site-nav a[aria-current="location"] {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 34rem) {
    .header-inner {
      flex-wrap: wrap;
      row-gap: var(--space-2);
    }
    .site-nav {
      order: 3;
      flex-basis: 100%;
      padding-block-start: var(--space-2);
      border-top: 1px solid var(--color-rule);
    }
    .site-nav ul {
      gap: var(--space-4);
    }
    .site-nav a {
      font-family: var(--font-mono);
      font-feature-settings: var(--font-features-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--tracking-smallcaps);
      text-transform: uppercase;
    }
  }
</style>
