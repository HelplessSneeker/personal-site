---
import { t, type Locale } from '../../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<section class="section fineprint-section" aria-label={t(locale, 'bundle.fineprint.hourly.label')}>
  <div class="container">
    <div class="fineprint-grid">
      <div class="fineprint-col">
        <p class="fineprint-col-label label-meta">{t(locale, 'bundle.fineprint.hourly.label')}</p>
        <h3 class="fineprint-col-title">{t(locale, 'bundle.fineprint.hourly.title')}</h3>
        <p class="fineprint-col-body">{t(locale, 'bundle.fineprint.hourly.body')}</p>
      </div>

      <div class="fineprint-col">
        <p class="fineprint-col-label label-meta">{t(locale, 'bundle.fineprint.domain.label')}</p>
        <h3 class="fineprint-col-title">{t(locale, 'bundle.fineprint.domain.title')}</h3>
        <p class="fineprint-col-body">{t(locale, 'bundle.fineprint.domain.body')}</p>
      </div>
    </div>

    <p class="fineprint-line fineprint-compliance">{t(locale, 'bundle.fineprint.compliance')}</p>
    <p class="fineprint-line fineprint-tax">{t(locale, 'bundle.fineprint.tax')}</p>
  </div>
</section>

<style>
  .fineprint-section {
    padding-block-start: var(--section-continued);
  }

  .fineprint-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 48rem) {
    .fineprint-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-7);
    }
  }

  .fineprint-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-rule);
    min-width: 0;
  }

  .fineprint-col-label {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .fineprint-col-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-lg);
    line-height: var(--lh-snug);
    color: var(--color-text);
    margin: 0;
  }

  .fineprint-col-body {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    margin: 0;
    text-wrap: pretty;
    max-width: 50ch;
  }

  .fineprint-line {
    margin: var(--space-6) 0 0 0;
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    color: var(--color-text-muted);
    max-width: 72ch;
    text-wrap: pretty;
  }

  .fineprint-compliance {
    color: var(--color-text);
  }

  .fineprint-tax {
    margin-top: var(--space-3);
  }
</style>
