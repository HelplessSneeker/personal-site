---
import type { Project } from '../data/projects';
import { t, type Locale } from '../i18n/util';
import ProjectMockup from './ProjectMockup.astro';

export interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;
const description = locale === 'de' ? project.descriptionDe : project.descriptionEn;
const status = locale === 'de' ? project.statusDe : project.statusEn;
const role = project.role ? (locale === 'de' ? project.role.de : project.role.en) : undefined;
const imageAlt = project.imageAlt ? (locale === 'de' ? project.imageAlt.de : project.imageAlt.en) : project.title;
---
<article class="project">
  <div class="project-visual">
    {project.image ? (
      <img
        class="project-image"
        src={project.image}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
        width="1200"
        height="900"
      />
    ) : project.visual ? (
      <ProjectMockup variant={project.visual} title={project.title} />
    ) : null}
  </div>
  <div class="project-body">
    <header class="project-header">
      <h3 class="project-title">{project.title}</h3>
      {project.isPlaceholder && (
        <span class="todo-placeholder">TODO</span>
      )}
    </header>

    <p class="project-desc">{description}</p>

    {role && (
      <p class="project-meta">
        <span class="meta-label">{t(locale, 'work.roleLabel')}</span>
        {role}{project.years && <span class="project-years"> · {project.years}</span>}
      </p>
    )}

    <div class="project-stack">
      <span class="meta-label">{t(locale, 'work.stackLabel')}</span>
      <ul>
        {project.stack.map((tech) => (
          <li class={tech.startsWith('[TODO') ? 'stack-item stack-item--todo' : 'stack-item'}>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    {status && <p class="project-status">{status}</p>}

    {project.links && project.links.length > 0 && (
      <ul class="project-links">
        {project.links.map((link) => (
          <li>
            <a href={link.href} rel="noopener external" target="_blank">
              {t(locale, link.labelKey)} ↗
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .project {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-6);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .project:first-child {
    border-top: none;
    padding-top: 0;
  }
  @media (max-width: 48rem) {
    .project {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }

  .project-visual {
    min-width: 0;
  }
  .project-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }
  .project-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }
  .project-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .project-title {
    font-size: var(--fs-xl);
    font-weight: 500;
    letter-spacing: -0.015em;
  }
  .project-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
  }
  .project-meta {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }
  .project-years {
    color: var(--color-text-subtle);
    font-variant-numeric: tabular-nums;
  }
  .meta-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    margin-right: var(--space-2);
  }

  .project-stack ul {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    vertical-align: middle;
  }
  .stack-item {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }
  .stack-item--todo {
    border-style: dashed;
    border-color: var(--color-todo-border);
    color: var(--color-todo-text);
    background: var(--color-todo-bg);
  }

  .project-status {
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
    font-style: italic;
  }

  .project-links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--fs-sm);
  }
</style>
