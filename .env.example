# Resend: create an API key at https://resend.com/api-keys
# and verify the sender domain (e.g. noessler.at) before sending from @noessler.at
RESEND_API_KEY=

# Cloudflare Turnstile: create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# For local dev you can use the documented test keys:
#   PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA   (always passes)
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Who receives contact form submissions
CONTACT_TO_EMAIL=benjamin@noessler.at
# The From address Resend sends from (must be on a verified domain)
CONTACT_FROM_EMAIL=website@noessler.at
