---
import type { Project } from '../data/projects';
import { t, type Locale } from '../i18n/util';
import ProjectMockup from './ProjectMockup.astro';

export interface Props {
  project: Project;
  locale: Locale;
  index: number;
}

const { project, locale, index } = Astro.props;
const description = locale === 'de' ? project.descriptionDe : project.descriptionEn;
const status = locale === 'de' ? project.statusDe : project.statusEn;
const role = project.role ? (locale === 'de' ? project.role.de : project.role.en) : undefined;
const context = project.context ? (locale === 'de' ? project.context.de : project.context.en) : undefined;
const imageAlt = project.imageAlt ? (locale === 'de' ? project.imageAlt.de : project.imageAlt.en) : project.title;

const contextLabel = locale === 'de' ? 'Kontext' : 'Context';
const roleLabel = locale === 'de' ? 'Rolle' : 'Role';
const yearsLabel = locale === 'de' ? 'Jahr' : 'Year';
const statusLabel = locale === 'de' ? 'Status' : 'Status';
const outcomeLabel = locale === 'de' ? 'Ergebnis' : 'Outcome';
const statusMap: Record<Project['status'], { de: string; en: string }> = {
  live: { de: 'Live', en: 'Live' },
  archived: { de: 'Archiviert', en: 'Archived' },
  'in-development': { de: 'In Arbeit', en: 'In progress' },
  'case-study': { de: 'Case Study', en: 'Case study' },
};
const statusText = status ?? (locale === 'de' ? statusMap[project.status].de : statusMap[project.status].en);
const outcome = project.outcome ? (locale === 'de' ? project.outcome.de : project.outcome.en) : undefined;
const testimonialQuote = project.testimonial
  ? locale === 'de'
    ? project.testimonial.quote.de
    : project.testimonial.quote.en
  : undefined;
const testimonialAuthor = project.testimonial?.author
  ? locale === 'de'
    ? project.testimonial.author.de
    : project.testimonial.author.en
  : undefined;
---
<article class="project" role="listitem">
  <header class="project-head">
    <span class="project-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
    <h3 class="project-title">{project.title}</h3>
  </header>

  <div class="project-body">
    <div class="project-text">
      <p class="project-desc">{description}</p>

      {outcome && (
        <p class="project-outcome">
          <span class="outcome-label" aria-hidden="true">{outcomeLabel}</span>
          <span class="outcome-text">{outcome}</span>
        </p>
      )}

      {testimonialQuote && !project.testimonial?.placeholder && (
        <figure class="project-testimonial">
          <blockquote class="testimonial-quote">{testimonialQuote}</blockquote>
          {testimonialAuthor && <figcaption class="testimonial-author">— {testimonialAuthor}</figcaption>}
        </figure>
      )}

      <dl class="project-meta">
        {context && (
          <div class="meta-row">
            <dt class="label-meta">{contextLabel}</dt>
            <dd>{context}</dd>
          </div>
        )}

        {role && (
          <div class="meta-row">
            <dt class="label-meta">{roleLabel}</dt>
            <dd>{role}</dd>
          </div>
        )}

        {project.years && (
          <div class="meta-row">
            <dt class="label-meta">{yearsLabel}</dt>
            <dd><span class="tabular">{project.years}</span></dd>
          </div>
        )}

        <div class="meta-row">
          <dt class="label-meta">{statusLabel}</dt>
          <dd>{statusText}</dd>
        </div>

        <div class="meta-row">
          <dt class="label-meta">{t(locale, 'work.stackLabel')}</dt>
          <dd>
            <ul class="stack-list">
              {project.stack.map((tech) => (
                <li class="stack-tech">{tech}</li>
              ))}
            </ul>
          </dd>
        </div>

        {project.links && project.links.length > 0 && (
          <div class="meta-row">
            <dt class="label-meta">{locale === 'de' ? 'Links' : 'Links'}</dt>
            <dd>
              <ul class="link-list">
                {project.links.map((link) => (
                  <li>
                    <a href={link.href} rel="noopener external" target="_blank">
                      {t(locale, link.labelKey)} <span aria-hidden="true">↗</span>
                    </a>
                  </li>
                ))}
              </ul>
            </dd>
          </div>
        )}
      </dl>
    </div>

    <figure class="project-figure">
      {project.image ? (
        <img
          class="project-image"
          src={project.image}
          alt={imageAlt}
          loading="lazy"
          decoding="async"
          width="1200"
          height="900"
        />
      ) : project.visual ? (
        <ProjectMockup variant={project.visual} title={project.title} />
      ) : null}
    </figure>
  </div>
</article>

<style>
  .project {
    display: block;
    padding-block: var(--space-7);
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 48rem) {
    .project {
      padding-block: var(--space-8);
    }
  }

  .project-head {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    gap: var(--space-4);
    align-items: baseline;
    margin-bottom: var(--space-5);
  }

  .project-index {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-2xl);
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--color-text-subtle);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-xl);
    line-height: 1.05;
    color: var(--color-text);
    text-wrap: balance;
  }

  .project-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 52rem) {
    .project-body {
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      gap: var(--space-8);
      align-items: start;
    }
  }
  /* Indent under the project title only when there's enough horizontal room. */
  @media (min-width: 64rem) {
    .project-body {
      padding-left: 4.5rem;
    }
  }

  .project-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    min-width: 0;
  }

  .project-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    max-width: 60ch;
  }

  /* Outcome — single soft-result line, visually elevated above the meta dl
     so readers register impact before specs. The accent rule echoes the
     hero's "start of article" mark to tie the case study back to the
     editorial system. */
  .project-outcome {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: baseline;
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    margin: 0;
    max-width: 60ch;
  }

  .outcome-label {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: var(--weight-medium);
    font-variant-caps: all-small-caps;
    letter-spacing: var(--tracking-smallcaps);
    color: var(--color-accent);
  }

  .outcome-text {
    font-size: var(--fs-md);
    line-height: 1.4;
    color: var(--color-text);
  }

  /* Testimonial pull-quote. The italic display face plus the em-dash
     attribution carries the "this is a quote" signal without an accent
     stripe — `.impeccable.md` rules out border-left indicators. */
  .project-testimonial {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 60ch;
  }

  .testimonial-quote {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-body);
    font-style: italic;
    letter-spacing: var(--tracking-heading-sm);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    text-wrap: pretty;
  }

  .testimonial-quote::before {
    content: '“';
    color: var(--color-accent);
    margin-right: 0.05em;
  }

  .testimonial-quote::after {
    content: '”';
    color: var(--color-accent);
    margin-left: 0.02em;
  }

  .testimonial-author {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .project-meta {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-rule);
  }

  .meta-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .project-meta dt {
    color: var(--color-text-subtle);
  }

  .project-meta dd {
    margin: 0;
    font-size: var(--fs-sm);
    color: var(--color-text);
    line-height: 1.5;
    min-width: 0;
  }

  .sep {
    color: var(--color-text-subtle);
  }

  .stack-list,
  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .stack-list li,
  .link-list li {
    display: inline-flex;
    align-items: baseline;
  }

  .stack-list li:not(:last-child)::after,
  .link-list li:not(:last-child)::after {
    content: '·';
    color: var(--color-text-subtle);
    margin-inline: 0.55em;
  }

  .stack-tech {
    color: var(--color-text);
  }

  .link-list a {
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  .project-figure {
    margin: 0;
    min-width: 0;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  @media (max-width: 52rem) {
    .project-head {
      grid-template-columns: 3rem 1fr auto;
      margin-bottom: var(--space-4);
    }
    .project-index {
      font-size: var(--fs-xl);
    }
    .meta-row {
      grid-template-columns: 4.2rem 1fr;
    }
  }
</style>
