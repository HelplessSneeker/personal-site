---
import '../styles/global.css';
import ScrollSectionIndicator, { type SectionRef } from '../components/ScrollSectionIndicator.astro';
import bricolageLatin from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url';
import generalSansVariable from '../assets/fonts/general-sans-variable.woff2?url';

export interface Props {
  title: string;
  description: string;
  locale: 'de' | 'en';
  altLocaleUrl?: string;
  canonicalPath?: string;
  ogImage?: string;
  sections?: SectionRef[];
}

const {
  title,
  description,
  locale,
  altLocaleUrl,
  canonicalPath = Astro.url.pathname,
  ogImage = '/og-image.png',
  sections,
} = Astro.props;

const navLabel = locale === 'de' ? 'Seitennavigation' : 'Page sections';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://benjamin.noessler.at';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Benjamin Nößler',
  jobTitle: locale === 'de' ? 'Fullstack-Entwickler' : 'Fullstack Developer',
  url: siteUrl,
  email: 'mailto:benjamin@noessler.at',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Wien',
    addressCountry: 'AT',
  },
  sameAs: [
    'https://github.com/HelplessSneeker',
    'https://www.linkedin.com/in/bf-noessler/',
  ],
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101316" media="(prefers-color-scheme: dark)" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preload" href={bricolageLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={generalSansVariable} as="font" type="font/woff2" crossorigin />

    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    {altLocaleUrl && (
      <link
        rel="alternate"
        hreflang={locale === 'de' ? 'en' : 'de'}
        href={`${siteUrl}${altLocaleUrl}`}
      />
    )}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === 'de' ? 'de_AT' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">{locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}</a>
    <slot />
    {sections && sections.length > 0 && (
      <ScrollSectionIndicator sections={sections} navLabel={navLabel} />
    )}

    <script>
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll<HTMLElement>('.section:not(.hero), .site-footer');

      if (prefersReduced || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
        );

        targets.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.92) {
            el.classList.add('is-visible');
          } else {
            observer.observe(el);
          }
        });
      }
    </script>
  </body>
</html>
