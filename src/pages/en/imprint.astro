---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { t, getAltUrl } from '../../i18n/util';

export const prerender = true;

const locale = 'en' as const;
const altUrl = getAltUrl(Astro.url.pathname, locale);
---
<LegalLayout
  title={t(locale, 'legal.imprint.title')}
  description={t(locale, 'legal.imprint.description')}
  locale={locale}
  altLocaleUrl={altUrl}
  canonicalPath="/en/imprint"
>
  <h2>Information pursuant to §5 ECG and §25 MedienG (Austria)</h2>
  <address>
    <strong>Benjamin Nößler</strong><br />
    Sole proprietorship<br />
    Fasangasse 26/4<br />
    1030 Vienna<br />
    Austria
  </address>
  <p>
    <strong>Email:</strong> <a href="mailto:benjamin@noessler.at">benjamin@noessler.at</a>
  </p>
  <p>
    <strong>Business activity:</strong> Services in automatic data processing and information
    technology (unregulated trade / freies Gewerbe under Austrian law)
  </p>
  <p>
    <strong>GISA number:</strong> 39647481
  </p>
  <p>
    <strong>VAT ID:</strong> None — small-business scheme under §6(1)(27) of the Austrian VAT Act
    (Kleinunternehmer; no VAT is charged or shown).
  </p>

  <h2>Trade authority, chamber and applicable law</h2>
  <p>
    <strong>Trade authority:</strong> Magistratisches Bezirksamt für den 3. Bezirk, Vienna
  </p>
  <p>
    <strong>Chamber membership:</strong> Vienna Economic Chamber (Wirtschaftskammer Wien),
    Professional Group for Management Consultancy, Accounting and Information Technology (UBIT) ·
    <a href="https://www.wko.at" rel="noopener external" target="_blank">wko.at ↗</a>
  </p>
  <p>
    <strong>Applicable legislation:</strong> Austrian Trade Regulation Act 1994
    (Gewerbeordnung 1994), available at
    <a href="https://www.ris.bka.gv.at" rel="noopener external" target="_blank">ris.bka.gv.at ↗</a>
  </p>

  <h2>Disclaimer</h2>
  <p>
    The content of this website has been prepared with the utmost care. However, no warranty is
    given for the accuracy, completeness or timeliness of the content.
  </p>
  <p>
    The operators of linked external sites are solely responsible for their content.
  </p>

  <h2>Copyright</h2>
  <p>
    All content on this website (text, images, graphics, layout) is protected by Austrian
    copyright law. Use beyond the limits of copyright law requires the author's written consent.
  </p>
</LegalLayout>
