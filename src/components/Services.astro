---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const landingBullets = tArray(locale, 'services.landing.bullets');
const hostingBullets = tArray(locale, 'services.hosting.bullets');
---
<section class="section services-section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <h2 id="services-heading" class="section-label">{t(locale, 'services.label')}</h2>
    <p class="services-intro">{t(locale, 'services.intro')}</p>

    <article class="service service-primary">
      <p class="service-index" aria-hidden="true"><span>01</span><span class="rule"></span></p>
      <h3 class="service-title">{t(locale, 'services.landing.title')}</h3>
      <p class="service-desc">{t(locale, 'services.landing.description')}</p>

      <dl class="service-meta">
        <div class="meta-row">
          <dt class="label-meta">{t(locale, 'services.scopeLabel')}</dt>
          <dd>
            <ul class="meta-list">
              {landingBullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </dd>
        </div>
        <div class="meta-row meta-row-anchor">
          <dt class="label-meta">{t(locale, 'services.priceAnchorLabel')}</dt>
          <dd class="price-anchor">{t(locale, 'services.landing.priceAnchor')}</dd>
        </div>
      </dl>
    </article>

    <article class="service service-primary">
      <p class="service-index" aria-hidden="true"><span>02</span><span class="rule"></span></p>
      <h3 class="service-title">{t(locale, 'services.hosting.title')}</h3>
      <p class="service-desc">{t(locale, 'services.hosting.description')}</p>

      <dl class="service-meta">
        <div class="meta-row">
          <dt class="label-meta">{t(locale, 'services.scopeLabel')}</dt>
          <dd>
            <ul class="meta-list">
              {hostingBullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </dd>
        </div>
        <div class="meta-row meta-row-anchor">
          <dt class="label-meta">{t(locale, 'services.priceAnchorLabel')}</dt>
          <dd class="price-anchor">{t(locale, 'services.hosting.priceAnchor')}</dd>
        </div>
      </dl>
    </article>

    <aside class="service-extension" aria-label={t(locale, 'services.extensionLabel')}>
      <p class="extension-label label-meta">{t(locale, 'services.extensionLabel')}</p>
      <h3 class="extension-title">{t(locale, 'services.fullstack.title')}</h3>
      <p class="extension-desc">{t(locale, 'services.fullstack.description')}</p>
    </aside>
  </div>
</section>

<style>
  .services-intro {
    font-size: var(--fs-lg);
    line-height: 1.4;
    color: var(--color-text);
    max-width: 44rem;
    margin-bottom: var(--space-8);
    text-wrap: pretty;
  }

  .service {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
  }

  .service-primary {
    max-width: 52rem;
  }

  .service-primary + .service-primary {
    margin-top: var(--space-9);
    padding-top: var(--space-7);
    border-top: 1px solid var(--color-rule);
  }

  .service-index {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
  }
  .service-index .rule {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
    display: block;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-xl);
    line-height: 1.1;
    color: var(--color-text);
    text-wrap: balance;
  }

  .service-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    max-width: 56ch;
  }

  .service-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin: var(--space-3) 0 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-rule);
  }

  .meta-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
  @media (min-width: 40rem) {
    .meta-row {
      grid-template-columns: 7rem 1fr;
      gap: var(--space-4);
      align-items: baseline;
    }
  }

  .service-meta dt {
    color: var(--color-text-subtle);
  }

  .service-meta dd {
    margin: 0;
  }

  .meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text);
  }

  .meta-list li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    align-items: baseline;
  }

  .meta-list li::before {
    content: '—';
    color: var(--color-text-subtle);
  }

  .price-anchor {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-md);
    color: var(--color-text);
    line-height: 1.4;
  }

  /* Extension card — clearly subordinate to the primary service.
     Smaller heading, narrower column, set apart with extra space and a
     subtle treatment. The asymmetry communicates "this is an addendum,
     not a co-equal offering." */
  .service-extension {
    margin-top: var(--space-9);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
    max-width: 44rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .extension-label {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .extension-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-lg);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0;
  }

  .extension-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }
</style>
