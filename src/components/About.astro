---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const paragraphs = tArray(locale, 'about.bodyParagraphs');
const metaItems = tArray(locale, 'about.metaItems');
const byline = t(locale, 'about.byline');
const aboutPagePath = locale === 'de' ? '/ueber' : '/en/about';
---
<section class="section about-section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <h2 id="about-heading" class="section-label">{t(locale, 'about.label')}</h2>
    <div class="about-body">
      {paragraphs.length > 0 && (
        <p class="about-text" set:html={paragraphs[0]}></p>
      )}
      {metaItems.length > 0 && (
        <ul class="about-meta" aria-hidden="true">
          {metaItems.map((item) => <li>{item}</li>)}
        </ul>
      )}
      {paragraphs.slice(1).map((paragraph) => (
        <p class="about-text" set:html={paragraph}></p>
      ))}
      <p class="about-more">
        <a href={aboutPagePath} class="about-more-link">
          {t(locale, 'about.moreLabel')} <span aria-hidden="true">→</span>
        </a>
      </p>
      <p class="about-byline label-meta" aria-hidden="true">
        <span class="byline-rule"></span>
        <span class="byline-text">{byline}</span>
      </p>
    </div>
  </div>
</section>

<style>
  /* Label sits above content, like every other section. */
  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 60ch;
  }

  .about-text {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    text-wrap: pretty;
  }

  .about-text:first-of-type::first-letter {
    font-family: var(--font-display);
    font-size: 1.4em;
    font-weight: var(--weight-medium);
    letter-spacing: -0.01em;
    padding-right: 0.06em;
  }

  .about-text :global(.inline-link) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .about-text :global(.inline-link:hover) {
    text-decoration-thickness: 2px;
  }

  /* Mono pull-out — employment / location / freelance metadata. Same
     vocabulary as the proof strip and the hero colophon. */
  .about-meta {
    list-style: none;
    padding: var(--space-3) 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  /* Link out to the full /ueber page — the deeper bio, work history and the
     technical detail live there so this section can stay short. Quiet
     text-link voice, accent on hover. */
  .about-more {
    margin: var(--space-1) 0 0 0;
  }
  .about-more-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-size: var(--fs-md);
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, currentColor 45%, transparent);
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
    transition: color var(--transition), text-decoration-color var(--transition);
  }
  .about-more-link:hover {
    color: var(--color-accent);
    text-decoration-color: currentColor;
  }

  .about-byline {
    margin-top: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    color: var(--color-text-subtle);
  }

  .byline-rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: var(--color-border-strong);
    flex-shrink: 0;
  }
</style>
