---
import { t, type Locale } from '../../i18n/util';
import ContactForm from '../ContactForm.astro';
import { socialLinks } from '../../data/social';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
// TODO Bundle-Loom-URL eintragen. Block rendert nur, wenn PUBLIC_LOOM_BUNDLE_URL gesetzt ist.
const loomUrl = import.meta.env.PUBLIC_LOOM_BUNDLE_URL;
---
<section class="section contact-section" id="contact" aria-labelledby="bundle-contact-heading">
  <div class="container contact-inner">
    <header class="contact-header">
      <p class="section-label">{t(locale, 'bundle.contact.kicker')}</p>
      <h2 id="bundle-contact-heading" class="contact-heading">{t(locale, 'bundle.contact.title')}</h2>
      <p class="contact-body">{t(locale, 'bundle.contact.body')}</p>

      {loomUrl && (
        <p class="contact-call">
          {t(locale, 'bundle.contact.loomIntro')}{' '}
          <a class="contact-call-link" href={loomUrl} rel="noopener external" target="_blank">
            {t(locale, 'bundle.contact.loomLinkLabel')} <span aria-hidden="true">→</span>
          </a>
        </p>
      )}

      <dl class="contact-direct">
        <div class="direct-row">
          <dt class="label-meta">{t(locale, 'contact.directEmailLabel')}</dt>
          <dd><a href="mailto:benjamin@noessler.at">benjamin@noessler.at</a></dd>
        </div>
        <div class="direct-row">
          <dt class="label-meta">{t(locale, 'contact.social.heading')}</dt>
          <dd>
            <ul class="social-list">
              {socialLinks.map((link) => (
                <li>
                  <a href={link.url} rel="noopener external me" target="_blank">
                    {link.label} <span aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </dd>
        </div>
      </dl>
    </header>

    <ContactForm locale={locale} />

    <noscript>
      <p class="contact-noscript">
        {t(locale, 'contact.noscript.before')}
        <a href="mailto:benjamin@noessler.at">benjamin@noessler.at</a>{t(locale, 'contact.noscript.after')}
      </p>
    </noscript>
  </div>
</section>

<style>
  .contact-section {
    padding-block-start: var(--section-pause);
  }

  .contact-inner {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: minmax(0, 1fr);
  }
  @media (min-width: 56rem) {
    .contact-inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: var(--space-9);
      align-items: start;
    }
  }

  .contact-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 32rem;
  }

  .contact-header .section-label {
    margin-bottom: 0;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-xl);
    line-height: 1.05;
    margin: 0;
    text-wrap: balance;
  }

  .contact-body {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    max-width: 44ch;
    text-wrap: pretty;
  }

  .contact-call {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    margin: var(--space-3) 0 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
  }
  .contact-call-link {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    color: var(--color-accent);
  }

  .contact-direct {
    margin: var(--space-5) 0 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-rule);
    display: grid;
    gap: var(--space-3);
  }

  .direct-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .contact-direct dt {
    color: var(--color-text-subtle);
  }

  .contact-direct dd {
    margin: 0;
    font-size: var(--fs-sm);
  }

  .contact-direct a {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
  }

  .social-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 0;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
  }

  .social-list li {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .social-list li:not(:last-child)::after {
    content: '·';
    color: var(--color-text-subtle);
    margin-inline: 0.55em;
  }

  .contact-noscript {
    margin-top: var(--space-5);
    padding: var(--space-4);
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }
</style>
