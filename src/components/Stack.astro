---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const groupKeys = ['languages', 'frontend', 'backend', 'infra', 'tools'] as const;
const groups = groupKeys.map((key) => ({
  key,
  label: t(locale, `stack.groups.${key}.label`),
  items: tArray(locale, `stack.groups.${key}.items`),
}));
---
<section class="section stack-section" id="stack" aria-labelledby="stack-heading">
  <div class="container">
    <details class="stack-details">
      <summary id="stack-heading" class="section-label stack-summary">
        {t(locale, 'stack.label')}
      </summary>

      <dl class="stack-groups">
        {groups.map((group, i) => (
          <div class="stack-group" style={`--i:${i}`}>
            <dt class="stack-group-label">{group.label}</dt>
            <dd class="stack-group-items">
              <ul>
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </dd>
          </div>
        ))}
      </dl>
    </details>
  </div>
</section>

<style>
  .stack-details {
    margin: 0;
  }

  .stack-summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: 0;
    user-select: none;
  }
  .stack-summary::-webkit-details-marker {
    display: none;
  }
  .stack-summary::after {
    content: '+';
    display: inline-block;
    font-family: var(--font-mono);
    color: var(--color-text-subtle);
    transition: transform var(--transition);
  }
  .stack-details[open] .stack-summary::after {
    content: '−';
  }
  .stack-summary:hover {
    color: var(--color-text-muted);
  }

  .stack-groups {
    display: grid;
    margin: var(--space-5) 0 0 0;
    border-top: 1px solid var(--color-rule);
  }

  .stack-group {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
  }

  @media (min-width: 40rem) {
    .stack-group {
      grid-template-columns: minmax(9rem, 12rem) 1fr;
      gap: var(--space-6);
      padding-block: var(--space-5);
    }
  }

  .stack-group-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .stack-group-items {
    margin: 0;
  }

  .stack-group-items ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 0;
    row-gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text);
    font-feature-settings: 'ss01';
  }

  .stack-group-items li {
    display: inline-flex;
    align-items: baseline;
  }

  .stack-group-items li:not(:last-child)::after {
    content: '·';
    color: var(--color-text-subtle);
    margin-inline: 0.55em;
  }
</style>
