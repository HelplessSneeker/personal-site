---
import { tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = tArray(locale, 'proof.items');
const navLabel = locale === 'de' ? 'Eckdaten' : 'At a glance';
---
<aside class="proof" aria-label={navLabel}>
  <div class="container">
    <ul class="proof-list">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</aside>

<style>
  /* Trust-band between Hero and Services. Not a `.section` — sits in the
     gap between two real sections and provides the divider line above
     Services via its own border-bottom. Set as an inline colophon line:
     four commitments separated by middle-dots, mono-tagged metadata voice,
     consistent with footer-legal and social-list patterns. */
  .proof {
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 48rem) {
    .proof {
      padding-block: var(--space-6);
    }
  }

  .proof-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    color: var(--color-text);
    line-height: 1.5;
  }

  .proof-list li {
    display: inline-flex;
    align-items: baseline;
  }

  .proof-list li:not(:last-child)::after {
    content: '·';
    color: var(--color-accent);
    margin-inline: 0.6em;
  }

  @media (max-width: 34rem) {
    .proof-list {
      font-size: var(--fs-sm);
    }
  }
</style>
