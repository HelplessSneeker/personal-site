---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Stack from '../../components/Stack.astro';
import SelectedWork from '../../components/SelectedWork.astro';
import About from '../../components/About.astro';
import Contact from '../../components/Contact.astro';
import { t, getAltUrl } from '../../i18n/util';

export const prerender = true;

const locale = 'en' as const;
const altUrl = getAltUrl(Astro.url.pathname, locale);

const sections = [
  { id: 'top', label: 'Start' },
  { id: 'services', label: t(locale, 'nav.services') },
  { id: 'work', label: t(locale, 'nav.work') },
  { id: 'about', label: t(locale, 'nav.about') },
  { id: 'contact', label: t(locale, 'nav.contact') },
];
---
<BaseLayout
  title={t(locale, 'site.title')}
  description={t(locale, 'site.description')}
  locale={locale}
  altLocaleUrl={altUrl}
  canonicalPath="/en/"
  sections={sections}
>
  <Header locale={locale} />
  <main id="main">
    <Hero locale={locale} />
    <Services locale={locale} />
    <SelectedWork locale={locale} />
    <Stack locale={locale} />
    <About locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
