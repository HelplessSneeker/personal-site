---
export interface Props {
  variant: 'mockup-calendar' | 'mockup-healthcare' | 'mockup-industrial';
  title: string;
}

const { variant, title } = Astro.props;

/* Editorial illustration system. Three deliberate motifs — calendar grid,
   encrypted-chat, instrumented-gauge — each carrying a single mono tag that
   names the project's defining technical move. Not a UI screenshot; a glyph. */
const tagByVariant: Record<Props['variant'], string> = {
  'mockup-calendar': '[OSS]',
  'mockup-healthcare': '[E2EE]',
  'mockup-industrial': '[SAP]',
};
const tag = tagByVariant[variant];
---
<div class={`mockup mockup--${variant}`} aria-hidden="true">
  <div class="mockup-content">
    {variant === 'mockup-calendar' && (
      <div class="calendar">
        <div class="cal-header">
          {[...Array(7)].map(() => <span class="cal-day-label"></span>)}
        </div>
        <div class="cal-grid">
          {[...Array(35)].map((_, i) => <span class={`cal-cell ${[4, 11, 17, 23].includes(i) ? 'has-event' : ''}`}></span>)}
        </div>
      </div>
    )}
    {variant === 'mockup-healthcare' && (
      <div class="chat">
        <div class="bubble left"><div class="line"></div><div class="line short"></div></div>
        <div class="bubble right"><div class="line"></div></div>
        <div class="bubble left"><div class="line"></div><div class="line"></div></div>
      </div>
    )}
    {variant === 'mockup-industrial' && (
      <div class="industrial">
        <div class="gauge"><div class="gauge-needle"></div></div>
        <div class="bars">
          <span style="height: 40%"></span>
          <span style="height: 65%"></span>
          <span style="height: 50%"></span>
          <span style="height: 80%"></span>
          <span style="height: 35%"></span>
        </div>
      </div>
    )}
  </div>
  <span class="mockup-tag" aria-hidden="true">{tag}</span>
  <span class="mockup-title">{title}</span>
</div>

<style>
  .mockup {
    position: relative;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .mockup-content {
    flex: 1;
    padding: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mockup-tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-smallcaps);
    color: var(--color-accent);
    background: var(--color-bg);
    padding: 2px 6px;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
  }
  .mockup-title {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
  }

  /* Calendar */
  .calendar {
    width: 100%;
    display: grid;
    gap: 4px;
  }
  .cal-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-day-label {
    height: 6px;
    background: var(--color-border);
    border-radius: 2px;
  }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-cell {
    aspect-ratio: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
  }
  .cal-cell.has-event {
    background: var(--color-accent-subtle);
    border-color: var(--color-accent);
  }

  /* Healthcare chat */
  .chat {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bubble {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 6px 10px;
    max-width: 65%;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bubble.left { align-self: flex-start; }
  .bubble.right { align-self: flex-end; background: var(--color-accent-subtle); border-color: var(--color-accent); }
  .bubble .line {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    width: 100%;
  }
  .bubble .line.short { width: 50%; }

  /* Industrial */
  .industrial {
    display: flex;
    gap: var(--space-5);
    align-items: flex-end;
    width: 100%;
    height: 100%;
  }
  .gauge {
    width: 80px;
    height: 80px;
    border: 2px solid var(--color-border);
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
    align-self: center;
  }
  .gauge-needle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    transform-origin: 0 50%;
    transform: rotate(-45deg);
  }
  .gauge::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  .bars {
    display: flex;
    gap: 6px;
    align-items: flex-end;
    height: 100%;
    flex: 1;
  }
  .bars span {
    flex: 1;
    background: var(--color-border);
    border-radius: 2px 2px 0 0;
  }
  .bars span:nth-child(4) {
    background: var(--color-accent);
  }

  @media (prefers-color-scheme: dark) {
    .mockup { background: var(--color-bg); }
  }
</style>
