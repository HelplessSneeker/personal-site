---
import { t, tArray, type Locale } from '../../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const snapshotItems = tArray(locale, 'bundle.hero.snapshotItems');
const metaItems = tArray(locale, 'bundle.hero.metaItems');
---
<section class="section bundle-hero" id="top" aria-labelledby="bundle-hero-heading">
  <div class="container bundle-hero-inner">
    <span class="bundle-hero-rule" aria-hidden="true"></span>
    <p class="bundle-hero-kicker label-meta">{t(locale, 'bundle.hero.kicker')}</p>
    <h1 id="bundle-hero-heading" class="bundle-hero-headline">{t(locale, 'bundle.hero.headline')}</h1>
    <p class="bundle-hero-body">{t(locale, 'bundle.hero.body')}</p>

    {snapshotItems.length > 0 && (
      <ul class="bundle-hero-snapshot tabular" aria-label={t(locale, 'bundle.hero.kicker')}>
        {snapshotItems.map((item) => <li>{item}</li>)}
      </ul>
    )}

    {metaItems.length > 0 && (
      <ul class="bundle-hero-meta" aria-hidden="true">
        {metaItems.map((item) => <li>{item}</li>)}
      </ul>
    )}
  </div>
</section>

<style>
  .bundle-hero {
    padding-block: var(--space-9) var(--space-7);
    border-top: none;
  }
  .bundle-hero + .section {
    border-top: none;
  }
  @media (min-width: 48rem) {
    .bundle-hero {
      padding-block: clamp(var(--space-9), 10vh, 8rem) var(--space-8);
    }
  }

  .bundle-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 56rem;
  }

  .bundle-hero-rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .bundle-hero-kicker {
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .bundle-hero-headline {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: clamp(2rem, 1.4rem + 3vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
    max-width: 22ch;
    text-wrap: balance;
    margin: 0 0 var(--space-5) 0;
  }

  .bundle-hero-body {
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    max-width: 56ch;
    text-wrap: pretty;
    margin: 0 0 var(--space-5) 0;
  }

  /* Above-the-fold price snapshot — three figures in the same mono colophon
     voice as Hero's meta and the page-wide proof bar. Heavier than the
     bundle-hero-meta below it (--fs-sm vs --fs-xs, --color-text vs subtle)
     because this is substantive content (the prices), not a colophon. */
  .bundle-hero-snapshot {
    list-style: none;
    padding: var(--space-3) 0;
    margin: 0 0 var(--space-5) 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-sm);
    color: var(--color-text);
    line-height: 1.5;
  }
  .bundle-hero-snapshot li {
    display: inline-flex;
    align-items: baseline;
  }
  .bundle-hero-snapshot li:not(:last-child)::after {
    content: '·';
    color: var(--color-accent);
    margin-inline: 0.55em;
  }

  .bundle-hero-meta {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
  .bundle-hero-meta li {
    display: inline-flex;
    align-items: baseline;
  }
  .bundle-hero-meta li:not(:last-child)::after {
    content: '·';
    color: var(--color-accent);
    margin-inline: 0.55em;
  }
</style>
