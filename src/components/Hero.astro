---
import { t, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getLocalizedPath(locale, '/');
---
<section class="section hero" id="top" aria-labelledby="hero-heading">
  <div class="container">
    <div class="hero-text">
      <h1 id="hero-heading" class="hero-headline">{t(locale, 'hero.headline')}</h1>
      <p class="hero-body">{t(locale, 'hero.body')}</p>

      <div class="hero-cta">
        <a href={`${home}#work`} class="btn btn-primary">{t(locale, 'hero.ctaPrimary')}</a>
        <a href={`${home}#contact`} class="btn btn-secondary">{t(locale, 'hero.ctaSecondary')}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-9) var(--space-8);
  }
  .hero + .section,
  .section.hero {
    border-top: none;
  }
  @media (min-width: 48rem) {
    .hero {
      padding-block: clamp(var(--space-9), 10vh, var(--space-10)) var(--space-9);
    }
  }

  .hero-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 450;
    font-size: var(--fs-display);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-text);
    max-width: 24ch;
    text-wrap: balance;
    margin-bottom: var(--space-5);
    font-feature-settings: 'ss01', 'ss02';
  }

  .hero-body {
    font-size: var(--fs-lg);
    line-height: 1.5;
    color: var(--color-text);
    max-width: 46ch;
    margin-bottom: var(--space-7);
    text-wrap: pretty;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
