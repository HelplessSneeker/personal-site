---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = tArray(locale, 'proof.items');
const navLabel = t(locale, 'proof.ariaLabel');
---
<aside class="proof" aria-label={navLabel}>
  <div class="container">
    <ul class="proof-list">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</aside>

<style>
  /* Running mark, not a section. Sits as a slim footnote-line between Hero
     and Services: small mono metadata voice, accent middle-dots, no padding
     band of its own. Border-bottom is the rule that would otherwise come
     from `.section + .section` — it belongs to Services' top edge, not to
     Proof's bottom. Pattern matches footer-legal / social-list. */
  .proof {
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 48rem) {
    .proof {
      padding-block: var(--space-4);
    }
  }

  .proof-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .proof-list li {
    display: inline-flex;
    align-items: baseline;
  }

  .proof-list li:not(:last-child)::after {
    content: '·';
    color: var(--color-accent);
    margin-inline: 0.55em;
  }

  @media (max-width: 34rem) {
    .proof-list {
      font-size: var(--fs-xs);
    }
  }
</style>
