---
import { t, getDict, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale) as unknown as {
  pricing: {
    addons: Array<{
      key: string;
      title: string;
      kicker: string;
      description: string;
      setup: string;
      monthly: string;
    }>;
  };
};
const addons = dict.pricing.addons;
---
<section class="section pricing-addons" id="addons" aria-labelledby="pricing-addons-heading">
  <div class="container">
    <h2 id="pricing-addons-heading" class="section-label">{t(locale, 'pricing.addonsSection.label')}</h2>
    <p class="section-lede">{t(locale, 'pricing.addonsSection.intro')}</p>

    <ol class="pricing-addons-list">
      {addons.map((addon, index) => (
        <li class="pricing-addon">
          <p class="pricing-addon-index tabular" aria-hidden="true">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <span class="rule"></span>
          </p>
          <p class="pricing-addon-kicker label-meta">{addon.kicker}</p>
          <h3 class="pricing-addon-title">{addon.title}</h3>
          <p class="pricing-addon-desc">{addon.description}</p>
          <dl class="pricing-addon-prices tabular">
            <div class="pricing-addon-price-row">
              <dt class="label-meta">Setup</dt>
              <dd>{addon.setup}</dd>
            </div>
            <div class="pricing-addon-price-row">
              <dt class="label-meta">Monatlich</dt>
              <dd>{addon.monthly}</dd>
            </div>
          </dl>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .pricing-addons {
    padding-block: var(--space-7);
  }
  @media (min-width: 48rem) {
    .pricing-addons {
      padding-block: var(--space-8);
    }
  }

  .pricing-addons-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 48rem) {
    .pricing-addons-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  .pricing-addon {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .pricing-addon-index {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .pricing-addon-index .rule {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
  }

  .pricing-addon-kicker {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .pricing-addon-title {
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-heading-lg);
    margin: 0;
    text-wrap: balance;
  }

  .pricing-addon-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-normal);
    color: var(--color-text);
    margin: 0;
    text-wrap: pretty;
  }

  .pricing-addon-prices {
    margin: var(--space-3) 0 0 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pricing-addon-price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }

  .pricing-addon-price-row dt {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .pricing-addon-price-row dd {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-md);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    margin: 0;
    white-space: nowrap;
  }
</style>
