---
import { t, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const pricingPath = getLocalizedPath(locale, locale === 'de' ? '/preise' : '/pricing');

/* The homepage Services section is the overview teaser; full prices, included
   lists, and the tax note live on the dedicated /preise page. The three
   editorial entries below carry kicker + title + description only, then hand
   off to the pricing page via the CTA. */
---
<section class="section services-section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <h2 id="services-heading" class="section-label">{t(locale, 'services.label')}</h2>
    <p class="section-lede">{t(locale, 'services.intro')}</p>

    <ol class="services-list">
      <li class="service-overview">
        <p class="service-overview-index tabular" aria-hidden="true">
          <span>01</span>
          <span class="rule"></span>
        </p>
        <p class="service-overview-kicker label-meta">{t(locale, 'services.website.kicker')}</p>
        <h3 class="service-overview-title">{t(locale, 'services.website.title')}</h3>
        <p class="service-overview-desc">{t(locale, 'services.website.description')}</p>
      </li>

      <li class="service-overview">
        <p class="service-overview-index tabular" aria-hidden="true">
          <span>02</span>
          <span class="rule"></span>
        </p>
        <p class="service-overview-kicker label-meta">{t(locale, 'services.care.kicker')}</p>
        <h3 class="service-overview-title">{t(locale, 'services.care.title')}</h3>
        <p class="service-overview-desc">{t(locale, 'services.care.description')}</p>
      </li>

      <li class="service-overview">
        <p class="service-overview-index tabular" aria-hidden="true">
          <span>03</span>
          <span class="rule"></span>
        </p>
        <p class="service-overview-kicker label-meta">{t(locale, 'services.tools.kicker')}</p>
        <h3 class="service-overview-title">{t(locale, 'services.tools.title')}</h3>
        <p class="service-overview-desc">{t(locale, 'services.tools.description')}</p>
      </li>
    </ol>

    <p class="services-ongoing">{t(locale, 'services.ongoingNote')}</p>

    <p class="services-details-cta">
      <a
        href={pricingPath}
        class="services-details-link"
        aria-label={t(locale, 'services.detailsCtaAria')}
      >
        {t(locale, 'services.detailsCta')}
        <span class="services-details-arrow" aria-hidden="true">→</span>
      </a>
    </p>

    <aside class="service-extension" aria-label={t(locale, 'services.extensionLabel')}>
      <p class="extension-label label-meta">{t(locale, 'services.extensionLabel')}</p>
      <h3 class="extension-title">{t(locale, 'services.fullstack.title')}</h3>
      <p class="extension-desc">{t(locale, 'services.fullstack.description')}</p>
    </aside>
  </div>
</section>

<style>
  .services-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }
  @media (min-width: 48rem) {
    .services-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-7);
    }
  }

  .service-overview {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .service-overview-index {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
  }
  .service-overview-index .rule {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
    display: block;
  }

  .service-overview-kicker {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .service-overview-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-heading-lg);
    color: var(--color-text);
    margin: 0;
    text-wrap: balance;
  }

  .service-overview-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    margin: 0;
    text-wrap: pretty;
  }

  /* The "we keep working" beat — sits just before the pricing CTA so the
     recurring-relationship framing reads as the bridge from overview to
     details. Editorial voice, slightly larger than body, max width tuned
     to read in 2 lines on desktop. */
  .services-ongoing {
    margin: var(--space-8) 0 0 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-rule);
    font-size: var(--fs-lg);
    line-height: 1.45;
    color: var(--color-text);
    max-width: 56ch;
    text-wrap: pretty;
  }

  .services-details-cta {
    margin: var(--space-5) 0 0 0;
  }

  .services-details-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--color-accent) 25%, transparent);
    text-underline-offset: 0.18em;
    text-decoration-thickness: 1px;
  }
  .services-details-link:hover {
    color: var(--color-accent-hover);
    text-decoration-color: currentColor;
  }
  .services-details-link:hover .services-details-arrow {
    transform: translateX(0.15em);
  }
  .services-details-arrow {
    transition: transform var(--transition);
  }
  @media (prefers-reduced-motion: reduce) {
    .services-details-arrow {
      transition: none;
    }
    .services-details-link:hover .services-details-arrow {
      transform: none;
    }
  }

  /* Extension card — clearly subordinate to the primary services. Unchanged
     from the previous Services layout; kept as a quiet aside for visitors
     who land on the page with a "bigger than a website" question. */
  .service-extension {
    margin-top: var(--space-9);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
    max-width: 44rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .extension-label {
    color: var(--color-text-subtle);
    margin: 0;
  }
  .extension-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-heading-lg);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0;
  }
  .extension-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0;
  }
</style>
