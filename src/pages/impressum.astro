---
import LegalLayout from '../layouts/LegalLayout.astro';
import { t, getAltUrl } from '../i18n/util';

export const prerender = true;

const locale = 'de' as const;
const altUrl = getAltUrl(Astro.url.pathname, locale);
---
<LegalLayout
  title={t(locale, 'legal.imprint.title')}
  description={t(locale, 'legal.imprint.description')}
  locale={locale}
  altLocaleUrl={altUrl}
  canonicalPath="/impressum"
>
