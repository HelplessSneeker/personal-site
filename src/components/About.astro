---
import { t, tArray, type Locale } from '../i18n/util';
import Stack from './Stack.astro';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const paragraphs = tArray(locale, 'about.bodyParagraphs');
const byline = t(locale, 'about.byline');
---
<section class="section about-section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <h2 id="about-heading" class="section-label">{t(locale, 'about.label')}</h2>
    <div class="about-body">
      {paragraphs.map((paragraph) => (
        <p class="about-text" set:html={paragraph}></p>
      ))}
      <p class="about-byline label-meta" aria-hidden="true">
        <span class="byline-rule"></span>
        <span class="byline-text">{byline}</span>
      </p>
    </div>
    <div class="about-stack">
      <Stack locale={locale} />
    </div>
  </div>
</section>

<style>
  /* Label sits above content, like every other section. The previous
     side-label grid (minmax(9rem,12rem):1fr at ≥48rem) broke that pattern
     and made About feel like a different system. */
  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 60ch;
  }

  .about-text {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    text-wrap: pretty;
  }

  .about-text:first-of-type::first-letter {
    font-family: var(--font-display);
    font-size: 1.4em;
    font-weight: var(--weight-medium);
    letter-spacing: -0.01em;
    padding-right: 0.06em;
  }

  .about-text :global(.inline-link) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .about-text :global(.inline-link:hover) {
    text-decoration-thickness: 2px;
  }

  .about-byline {
    margin-top: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    color: var(--color-text-subtle);
  }

  .byline-rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: var(--color-border-strong);
    flex-shrink: 0;
  }

  /* Stack disclosure sits below the body at full container width — its
     expanded content benefits from running wider than the 60ch prose. */
  .about-stack {
    margin-top: var(--space-7);
  }
</style>
