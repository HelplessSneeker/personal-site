---
import { t, tArray, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getLocalizedPath(locale, '/');
const metaItems = tArray(locale, 'hero.meta');
---
<section class="section hero" id="top" aria-labelledby="hero-heading">
  <div class="container hero-grid">
    <div class="hero-text">
      <span class="hero-rule" aria-hidden="true"></span>
      <p class="hero-kicker label-meta">{t(locale, 'hero.kicker')}</p>
      <h1 id="hero-heading" class="hero-headline">{t(locale, 'hero.headline')}</h1>
      <p class="hero-body">{t(locale, 'hero.body')}</p>

      <div class="hero-cta">
        <a href={`${home}#contact`} class="btn btn-primary hero-cta-primary">
          {t(locale, 'hero.ctaPrimary')}
          <span class="hero-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href={`${home}#work`} class="hero-cta-link">
          {t(locale, 'hero.ctaSecondary')}
        </a>
      </div>
    </div>

    <aside class="hero-meta" aria-label={t(locale, 'availability.label')}>
      <span class="availability-pill">
        <span class="availability-dot" aria-hidden="true"></span>
        {t(locale, 'availability.value')}
      </span>
      {metaItems.length > 0 && (
        <ul class="hero-meta-list" aria-hidden="true">
          {metaItems.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </aside>
  </div>
</section>

<style>
  /* Documented exception to the section grammar.
     Hero is the page overture, not a section in the section sequence:
     - uses <h1> (not the .section-label h2)
     - draws the editorial start-rule above the kicker
     - intentionally has no top border (overrides .section + .section)
     - keeps a bespoke padding clamp because it owns the whole top of the page. */
  .hero {
    padding-block: var(--space-9) var(--space-8);
  }
  .hero + .section,
  .section.hero {
    border-top: none;
  }
  @media (min-width: 48rem) {
    .hero {
      padding-block: clamp(var(--space-10), 14vh, 11rem) var(--space-9);
    }
  }

  /* Hero composition.
     Mobile: single column, metadata stacks below the body text.
     Desktop (≥48rem): asymmetric 1.3fr / 1fr split — left column is the
     editorial overture (kicker, headline, body, CTAs); right column is a
     metadata panel (availability pill + dot-separated mono colophon).
     The asymmetry comes from the right column being narrower than the left,
     not from centering — left-aligned text throughout. */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  @media (min-width: 48rem) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.3fr) minmax(12rem, 1fr);
      gap: var(--space-8);
    }
  }

  .hero-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Right column: metadata panel.
     Holds the availability pill (the brief's named "break-the-grid" moment;
     it appears here once and not again in Trust) plus a mono colophon line
     that mirrors the proof-bar's middle-dot pattern.
     On desktop the panel sits flush with the top of the headline, not
     baseline-aligned with the body — so the pill reads as a counterweight
     to the kicker, both at the page's top edge. */
  .hero-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    margin-top: var(--space-2);
  }
  @media (min-width: 48rem) {
    .hero-meta {
      align-self: start;
      padding-top: var(--space-3);
    }
  }

  .availability-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
  }

  .availability-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* Colophon-style mono caption — same vocabulary as Proof / footer-legal /
     social-list. Middle-dots in accent color; quiet line height. */
  .hero-meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-subtle);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
  .hero-meta-list li {
    display: inline-flex;
    align-items: baseline;
  }
  .hero-meta-list li:not(:last-child)::after {
    content: '·';
    color: var(--color-accent);
    margin-inline: 0.55em;
  }

  /* Leading editorial rule — "start of article" mark, common in print and
     long-form web. Keeps the kicker from sitting visually orphaned at the
     top of an otherwise generous whitespace block. */
  .hero-rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    background: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .hero-kicker {
    color: var(--color-text-subtle);
    margin-bottom: var(--space-5);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: clamp(2.75rem, 1.6rem + 5.5vw, 6.25rem);
    line-height: 1.0;
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
    max-width: 18ch;
    text-wrap: balance;
    margin-bottom: var(--space-6);
  }
  @media (min-width: 64rem) {
    .hero-headline {
      max-width: 14ch;
    }
  }

  .hero-body {
    font-size: var(--fs-lg);
    line-height: 1.5;
    color: var(--color-text);
    max-width: 46ch;
    margin-bottom: var(--space-8);
    text-wrap: pretty;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
  }

  /* Hero-scoped override: the primary CTA is the conversion path of the
     whole site, so it earns more padding, more weight, and a subtle lift
     on hover. The secondary link stays a quiet text-link — that contrast
     is the point. */
  .hero-cta-primary {
    padding: var(--space-4) var(--space-6);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    min-height: 52px;
    gap: var(--space-3);
  }
  .hero-cta-primary:hover {
    transform: translateY(-1px);
  }
  .hero-cta-primary .hero-cta-arrow {
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: 0.95em;
    display: inline-block;
    transition: transform var(--transition);
  }
  .hero-cta-primary:hover .hero-cta-arrow {
    transform: translateX(3px);
  }

  .hero-cta-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-size: var(--fs-md);
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, currentColor 45%, transparent);
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
    transition: color var(--transition), text-decoration-color var(--transition);
  }
  .hero-cta-link:hover {
    color: var(--color-accent);
    text-decoration-color: currentColor;
  }
</style>
