---
import { t, type Locale, getLocalizedPath } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const bundlePath = getLocalizedPath(locale, '/bundle');
---
<section class="section services-section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <h2 id="services-heading" class="section-label">{t(locale, 'services.label')}</h2>
    <p class="section-lede">{t(locale, 'services.intro')}</p>

    <ol class="services-list">
      <li class="service-overview">
        <p class="service-overview-index tabular" aria-hidden="true">
          <span>01</span>
          <span class="rule"></span>
        </p>
        <p class="service-overview-kicker label-meta">{t(locale, 'services.sites.kicker')}</p>
        <h3 class="service-overview-title">{t(locale, 'services.sites.title')}</h3>
        <p class="service-overview-desc">{t(locale, 'services.sites.description')}</p>
      </li>

      <li class="service-overview">
        <p class="service-overview-index tabular" aria-hidden="true">
          <span>02</span>
          <span class="rule"></span>
        </p>
        <p class="service-overview-kicker label-meta">{t(locale, 'services.ai.kicker')}</p>
        <h3 class="service-overview-title">{t(locale, 'services.ai.title')}</h3>
        <p class="service-overview-desc">{t(locale, 'services.ai.description')}</p>
      </li>

      <li class="service-overview">
        <p class="service-overview-index tabular" aria-hidden="true">
          <span>03</span>
          <span class="rule"></span>
        </p>
        <p class="service-overview-kicker label-meta">{t(locale, 'services.stack.kicker')}</p>
        <h3 class="service-overview-title">{t(locale, 'services.stack.title')}</h3>
        <p class="service-overview-desc">{t(locale, 'services.stack.description')}</p>
      </li>
    </ol>

    <p class="services-details-cta">
      <a
        href={bundlePath}
        class="services-details-link"
        aria-label={t(locale, 'services.detailsCtaAria')}
      >
        {t(locale, 'services.detailsCta')}
        <span class="services-details-arrow" aria-hidden="true">→</span>
      </a>
    </p>
  </div>
</section>

<style>
  .services-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }
  @media (min-width: 48rem) {
    .services-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-7);
    }
  }

  .service-overview {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .service-overview-index {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
  }
  .service-overview-index .rule {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
    display: block;
  }

  .service-overview-kicker {
    color: var(--color-text-subtle);
    margin: 0;
  }

  .service-overview-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--weight-medium);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-heading-lg);
    color: var(--color-text);
    margin: 0;
    text-wrap: balance;
  }

  .service-overview-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    margin: 0;
    text-wrap: pretty;
  }

  .services-details-cta {
    margin: var(--space-8) 0 0 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-rule);
  }

  .services-details-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--fs-md);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--color-accent) 25%, transparent);
    text-underline-offset: 0.18em;
    text-decoration-thickness: 1px;
  }
  .services-details-link:hover {
    color: var(--color-accent-hover);
    text-decoration-color: currentColor;
  }
  .services-details-link:hover .services-details-arrow {
    transform: translateX(0.15em);
  }
  .services-details-arrow {
    transition: transform var(--transition);
  }
  @media (prefers-reduced-motion: reduce) {
    .services-details-arrow {
      transition: none;
    }
    .services-details-link:hover .services-details-arrow {
      transform: none;
    }
  }
</style>
