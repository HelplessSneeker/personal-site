---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const groupKeys = ['languages', 'frontend', 'backend', 'infra', 'tools'] as const;
const groups = groupKeys.map((key) => ({
  key,
  label: t(locale, `stack.groups.${key}.label`),
  items: tArray(locale, `stack.groups.${key}.items`),
}));

const triggerLabel = locale === 'de' ? 'Stack im Detail' : 'Stack in detail';
const triggerHint =
  locale === 'de'
    ? 'Sprachen, Frameworks, Infrastruktur'
    : 'Languages, frameworks, infrastructure';
---
<details class="stack-disclosure" id="stack">
  <summary class="stack-trigger">
    <span class="stack-trigger-text">
      <span class="stack-trigger-label">{triggerLabel}</span>
      <span class="stack-trigger-hint">{triggerHint}</span>
    </span>
    <span class="stack-trigger-icon" aria-hidden="true"></span>
  </summary>

  <dl class="stack-groups">
    {groups.map((group, i) => (
      <div class="stack-group" style={`--i:${i}`}>
        <dt class="stack-group-label">{group.label}</dt>
        <dd class="stack-group-items">
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </dd>
      </div>
    ))}
  </dl>
</details>

<style>
  .stack-disclosure {
    margin: 0;
  }

  .stack-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: border-color var(--transition);
  }
  .stack-trigger::-webkit-details-marker {
    display: none;
  }
  .stack-trigger:hover,
  .stack-trigger:focus-visible {
    border-top-color: var(--color-border-strong);
    border-bottom-color: var(--color-border-strong);
  }
  .stack-trigger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .stack-trigger-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .stack-trigger-label {
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    font-size: var(--fs-lg);
    line-height: 1.15;
    letter-spacing: var(--tracking-heading-lg);
    color: var(--color-text);
  }

  .stack-trigger-hint {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: var(--weight-medium);
    font-variant-caps: all-small-caps;
    letter-spacing: var(--tracking-smallcaps);
    color: var(--color-text-subtle);
  }

  .stack-trigger-icon {
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-md);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      color var(--transition),
      border-color var(--transition),
      background-color var(--transition);
  }
  .stack-trigger-icon::before {
    content: '+';
  }
  .stack-disclosure[open] .stack-trigger-icon::before {
    content: '−';
  }
  .stack-trigger:hover .stack-trigger-icon,
  .stack-trigger:focus-visible .stack-trigger-icon {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  .stack-groups {
    display: grid;
    margin: 0;
  }

  .stack-group {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
  }
  /* Last tier merges into the disclosure's bottom border. */
  .stack-group:last-child {
    border-bottom: 0;
  }

  @media (min-width: 40rem) {
    .stack-group {
      grid-template-columns: minmax(9rem, 12rem) 1fr;
      gap: var(--space-6);
      padding-block: var(--space-5);
    }
  }

  .stack-group-label {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: var(--weight-medium);
    font-variant-caps: all-small-caps;
    letter-spacing: var(--tracking-smallcaps);
    color: var(--color-text-muted);
    margin: 0;
  }

  .stack-group-items {
    margin: 0;
  }

  .stack-group-items ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 0;
    row-gap: var(--space-1);
    font-family: var(--font-mono);
    font-feature-settings: var(--font-features-mono);
    font-size: var(--fs-sm);
    color: var(--color-text);
  }

  .stack-group-items li {
    display: inline-flex;
    align-items: baseline;
  }

  .stack-group-items li:not(:last-child)::after {
    content: '·';
    color: var(--color-text-subtle);
    margin-inline: 0.55em;
  }
</style>
