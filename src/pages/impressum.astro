---
import LegalLayout from '../layouts/LegalLayout.astro';
import { t, getAltUrl } from '../i18n/util';

export const prerender = true;

const locale = 'de' as const;
const altUrl = getAltUrl(Astro.url.pathname, locale);
---
<LegalLayout
  title={t(locale, 'legal.imprint.title')}
  description={t(locale, 'legal.imprint.description')}
  locale={locale}
  altLocaleUrl={altUrl}
  canonicalPath="/impressum"
>
  <h2>Angaben gemäß §5 ECG, §25 MedienG</h2>
  <address>
    <strong>Benjamin Nößler</strong><br />
    Einzelunternehmen<br />
    Fasangasse 26/4<br />
    1030 Wien<br />
    Österreich
  </address>
  <p>
    <strong>E-Mail:</strong> <a href="mailto:benjamin@noessler.at">benjamin@noessler.at</a>
  </p>
  <p>
    <strong>Unternehmensgegenstand:</strong> Dienstleistungen in der automatischen Datenverarbeitung
    und Informationstechnik (freies Gewerbe)
  </p>
  <p>
    <strong>GISA-Zahl:</strong> 39647481
  </p>
  <p>
    <strong>UID-Nummer:</strong> Nicht UID-pflichtig — Kleinunternehmer gemäß §6 Abs. 1 Z 27 UStG
    (keine Umsatzsteuer-Ausweisung).
  </p>

  <h2>Gewerbebehörde, Kammer und Rechtsvorschriften</h2>
  <p>
    <strong>Gewerbebehörde:</strong> Magistratisches Bezirksamt für den 3. Bezirk, Wien
  </p>
  <p>
    <strong>Mitgliedschaft:</strong> Wirtschaftskammer Wien, Fachgruppe Unternehmensberatung,
    Buchhaltung und Informationstechnologie (UBIT) ·
    <a href="https://www.wko.at" rel="noopener external" target="_blank">wko.at ↗</a>
  </p>
  <p>
    <strong>Anwendbare Rechtsvorschrift:</strong> Gewerbeordnung 1994 (GewO), abrufbar unter
    <a href="https://www.ris.bka.gv.at" rel="noopener external" target="_blank">ris.bka.gv.at ↗</a>
  </p>

  <h2>Haftungsausschluss</h2>
  <p>
    Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt. Für die Richtigkeit,
    Vollständigkeit und Aktualität der Inhalte wird jedoch keine Gewähr übernommen.
  </p>
  <p>
