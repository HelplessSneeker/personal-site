# SMTP relay — the contact form authenticates against your existing
# mailbox and sends through it. For IONOS, defaults are:
#   SMTP_HOST=smtp.ionos.de   (or smtp.ionos.com / .at depending on account region)
#   SMTP_PORT=587             (STARTTLS)
#   SMTP_SECURE=false         (set to "true" only for implicit-TLS port 465)
#   SMTP_USER=<full email>    (the address you authenticate as; also becomes the From)
#   SMTP_PASS=<mailbox password>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Who receives contact form submissions
CONTACT_TO_EMAIL=benjamin@noessler.at

# Optional: when set, the contact section shows a 'book a 15-min call' link
# pointing to this URL (e.g. a Cal.com self-host on Coolify). Leave empty
# to hide the call-booking block entirely.
PUBLIC_CAL_URL=
