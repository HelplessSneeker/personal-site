---
import { t, tArray, type Locale } from '../i18n/util';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const landingBullets = tArray(locale, 'services.landing.bullets');
const fullstackBullets = tArray(locale, 'services.fullstack.bullets');
const includesLabel = locale === 'de' ? 'Umfang' : 'Includes';
---
<section class="section services-section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <h2 id="services-heading" class="section-label">{t(locale, 'services.label')}</h2>
    <p class="services-intro">{t(locale, 'services.intro')}</p>

    <div class="services-grid">
      <article class="service">
        <p class="service-index" aria-hidden="true"><span>01</span><span class="rule"></span></p>
        <h3 class="service-title">{t(locale, 'services.landing.title')}</h3>
        <p class="service-desc">{t(locale, 'services.landing.description')}</p>
        <dl class="service-meta">
          <dt>{includesLabel}</dt>
          <dd>
            <ul>
              {landingBullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </dd>
        </dl>
      </article>

      <article class="service">
        <p class="service-index" aria-hidden="true"><span>02</span><span class="rule"></span></p>
        <h3 class="service-title">{t(locale, 'services.fullstack.title')}</h3>
        <p class="service-desc">{t(locale, 'services.fullstack.description')}</p>
        <dl class="service-meta">
          <dt>{includesLabel}</dt>
          <dd>
            <ul>
              {fullstackBullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </dd>
        </dl>
      </article>
    </div>
  </div>
</section>

<style>
  .services-intro {
    font-size: var(--fs-lg);
    line-height: 1.4;
    color: var(--color-text);
    max-width: 38rem;
    margin-bottom: var(--space-8);
    text-wrap: pretty;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 52rem) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: var(--space-8);
      row-gap: var(--space-7);
      align-items: start;
    }
  }

  .service {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
  }

  .service-index {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-feature-settings: 'ss01';
  }
  .service-index .rule {
    flex: 1;
    height: 1px;
    background: var(--color-rule);
    display: block;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 500;
    letter-spacing: -0.018em;
    line-height: 1.1;
    color: var(--color-text);
    text-wrap: balance;
  }

  .service-desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-text);
    max-width: 36ch;
  }

  .service-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    margin: var(--space-2) 0 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-rule);
  }

  .service-meta dt {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: 500;
    font-variant-caps: all-small-caps;
    letter-spacing: 0.05em;
    color: var(--color-text-subtle);
  }

  .service-meta dd {
    margin: 0;
  }

  .service-meta ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--color-text);
  }

  .service-meta li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    align-items: baseline;
  }

  .service-meta li::before {
    content: '—';
    color: var(--color-text-subtle);
  }
</style>
